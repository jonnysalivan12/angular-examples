{
  "$schema": "../node_modules/@angular-devkit/schematics/collection-schema.json",
  "schematics": {
    "endpoint": {
      "description": "Endpoint generator",
      "factory": "./endpoint/index#endpoint",
      "schema": "./endpoint/schema.json"
    },
    "init-state": {
      "description": "Init a new state",
      "factory": "./state-factory/index#initState",
      "schema": "./state-factory/schemas/init-state-schema.json"
    },
    "add-state-action": {
      "description": "Add a new action into selected state",
      "factory": "./state-factory/index#addStateAction",
      "schema": "./state-factory/schemas/add-state-action-schema.json"
    },
    "add-async-state-action": {
      "description": "Add a new async action into selected state",
      "factory": "./state-factory/index#addAsyncStateAction",
      "schema": "./state-factory/schemas/add-async-state-action-schema.json"
    }
  }
}
