+/* eslint-disable @nx/enforce-module-boundaries */
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { resolvePipelineScope } from './pipeline-scope.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Testy resolvera PIPELINE_SCOPE: unia presetów z jawnymi listami (dedup+sort),
+ * walidacja warstw względem słownika, nieznany preset = throw, predykaty, isEmpty.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const VOCAB = ['type_state', 'type_ui', 'type_core', 'type_feature', 'app_shell'];
+
+test('pusty scope → isEmpty, wszystkie listy puste', () => {
+  const r = resolvePipelineScope({}, VOCAB);
+  assert.equal(r.isEmpty, true);
+  assert.deepEqual(r.layers, []);
+  assert.deepEqual(r.sections, []);
+  assert.deepEqual(r.standards, []);
+});
+
+test('jawne listy: dedup + sort + predykaty', () => {
+  const r = resolvePipelineScope(
+    { disabledLayers: ['type_ui', 'type_ui'], disabledStandards: ['b.md', 'a.md'] },
+    VOCAB,
+  );
+  assert.deepEqual(r.layers, ['type_ui']);
+  assert.deepEqual(r.standards, ['a.md', 'b.md']);
+  assert.equal(r.isLayerDisabled('type_ui'), true);
+  assert.equal(r.isLayerDisabled('type_state'), false);
+  assert.equal(r.isStandardDisabled('a.md'), true);
+  assert.equal(r.isEmpty, false);
+});
+
+test('preset rozwijany i unijny z jawnymi listami', () => {
+  const r = resolvePipelineScope(
+    {
+      apply: ['no-ui'],
+      disabledStandards: ['i18n.md'],
+      presets: {
+        'no-ui': { disabledLayers: ['type_ui'], disabledSections: ['design'], disabledStandards: ['a11y.md'] },
+      },
+    },
+    VOCAB,
+  );
+  assert.deepEqual(r.layers, ['type_ui']);
+  assert.deepEqual(r.sections, ['design']);
+  assert.deepEqual(r.standards, ['a11y.md', 'i18n.md']); // unia preset ∪ jawna, posortowana
+});
+
+test('warstwa spoza słownika → throw', () => {
+  assert.throws(
+    () => resolvePipelineScope({ disabledLayers: ['type_bogus'] }, VOCAB),
+    /spoza słownika/,
+  );
+});
+
+test('nieznany preset w apply → throw', () => {
+  assert.throws(
+    () => resolvePipelineScope({ apply: ['ghost'], presets: {} }, VOCAB),
+    /nieznany preset/,
+  );
+});
+
+test('brak słownika → walidacja warstw pominięta (nie rzuca)', () => {
+  const r = resolvePipelineScope({ disabledLayers: ['cokolwiek'] }, []);
+  assert.deepEqual(r.layers, ['cokolwiek']);
+});
