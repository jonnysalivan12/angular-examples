+ * Ostrzeżenie o punkcie wejścia PIPELINE_SCOPE. Każda oś scope'u (warstwy/sekcje/
+ * standardy) aktywuje się na SWOIM etapie; uruchomienie kroku PONIŻEJ tego etapu
+ * bez świeżego upstream sprawia, że wyłączenie nie jest odzwierciedlone (np. stary
+ * story-layers.yaml wciąż ma warstwę „wyłączoną" w configu). Czysto informacyjne.
+ */
+function warnScopeEntryPoints(chosenIndex) {
+  const scope = globalConfig.PIPELINE_SCOPE;
+  if (scope.isEmpty) return;
+  const axes = [
+    { active: scope.layers.length > 0,    stageKey: 'story-decomposer', label: `disabledLayers (${scope.layers.join(', ')})` },
+    { active: scope.sections.length > 0,  stageKey: 'story-clarifier',  label: `disabledSections (${scope.sections.join(', ')})` },
+    { active: scope.standards.length > 0, stageKey: 'planner',          label: `disabledStandards (${scope.standards.join(', ')})` },
+  ];
+  const lines = [];
+  for (const a of axes) {
+    if (!a.active) continue;
+    const entryIndex = STAGES.findIndex((s) => s.key === a.stageKey);
+    if (chosenIndex > entryIndex) {
+      lines.push(`• ${a.label} wchodzi w „${STAGES[entryIndex].label}" — uruchom od tego kroku, by zmiana zeszła w dół.`);
+    }
+  }
+  if (lines.length > 0) {
+    note(lines.join('\n'), 'Aktywny PIPELINE_SCOPE — uwaga na punkt wejścia');
+  }
+}
