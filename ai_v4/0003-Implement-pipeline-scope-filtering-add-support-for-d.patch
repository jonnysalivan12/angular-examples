+/* eslint-disable @nx/enforce-module-boundaries */
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { filterDisabledLayers, validateGraph, deriveSections } from './graph.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Testy filtra wyłączonych warstw (oś A scope'u). Graf bazowy:
+ *   type_state  (źródło) provides DATA
+ *   type_feature needs DATA  (konsument)
+ *   type_ui      needs DATA  (konsument-liść)
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const baseLayers = () => ({
+  type_state:   { requirement: 'r', acceptance_criteria: ['a'], provides: ['DATA'], needs: [] },
+  type_feature: { requirement: 'r', acceptance_criteria: ['a'], provides: ['VIEW'], needs: [{ from: 'type_state', key: 'DATA', why: 'w' }] },
+  type_ui:      { requirement: 'r', acceptance_criteria: ['a'], provides: ['WIDGET'], needs: [{ from: 'type_state', key: 'DATA', why: 'w' }] },
+});
+
+test('brak wyłączeń → identyczny obiekt, zero konfliktów', () => {
+  const layers = baseLayers();
+  const out = filterDisabledLayers({ layers, disabled: [] });
+  assert.equal(out.layers, layers);
+  assert.deepEqual(out.conflicts, []);
+});
+
+test('wyłączenie warstwy-liścia (type_ui) → usunięta, zero konfliktów, reszta spójna', () => {
+  const { layers, conflicts } = filterDisabledLayers({ layers: baseLayers(), disabled: ['type_ui'] });
+  assert.deepEqual(Object.keys(layers).sort(), ['type_feature', 'type_state']);
+  assert.deepEqual(conflicts, []);
+  // Po filtrze graf przechodzi walidację i derywuje sekcje bez UI.
+  const v = validateGraph({ layers, story: '' });
+  assert.equal(v.valid, true, JSON.stringify(v.errors));
+  const { fulfillment_order, placeholders } = deriveSections({ layers });
+  assert.ok(fulfillment_order.length >= 1);
+  assert.ok(placeholders.find(p => p.key === 'DATA' && p.provided_by === 'type_state'));
+  // WIDGET (provides type_ui) zniknął z rejestru kluczy.
+  assert.equal(placeholders.find(p => p.key === 'WIDGET'), undefined);
+});
+
+test('wyłączenie warstwy-źródła (type_state) → twardy konflikt dla konsumentów', () => {
+  const { conflicts } = filterDisabledLayers({ layers: baseLayers(), disabled: ['type_state'] });
+  const fromLayers = conflicts.map(c => c.layer).sort();
+  assert.deepEqual(fromLayers, ['type_feature', 'type_ui']);
+  assert.ok(conflicts.every(c => c.from === 'type_state' && c.key === 'DATA'));
+});
+
+test('needs: from external nie jest konfliktem przy wyłączaniu warstwy', () => {
+  const layers = {
+    type_state:   { requirement: 'r', acceptance_criteria: ['a'], provides: ['DATA'], needs: [{ from: 'external', key: 'API', why: 'w' }] },
+    type_ui:      { requirement: 'r', acceptance_criteria: ['a'], provides: ['W'], needs: [{ from: 'type_state', key: 'DATA', why: 'w' }] },
+  };
+  const { layers: kept, conflicts } = filterDisabledLayers({ layers, disabled: ['type_ui'] });
+  assert.deepEqual(Object.keys(kept), ['type_state']);
+  assert.deepEqual(conflicts, []);
+  // external need zachowany.
+  assert.deepEqual(kept.type_state.needs, [{ from: 'external', key: 'API', why: 'w' }]);
+});
