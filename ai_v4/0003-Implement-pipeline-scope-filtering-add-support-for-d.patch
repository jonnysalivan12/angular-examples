@@ -0,0 +1,55 @@
+/* eslint-disable @nx/enforce-module-boundaries */
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { loadChecklistSections, loadChecklistGroups } from './sections-loader.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Testy filtra wyłączonych sekcji (oś B1 scope'u) na REALNEJ checkliście DoR.
+ * Uruchamiać z roota repo (cwd-relative load).
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const CHECKLIST = '.github/agents/story-flow/story-clarifier/checklists/story-readiness.yaml';
+
+const idxUnion = (groups) => groups.flatMap(g => g.sectionIndices).sort((a, b) => a - b);
+
+test('baseline (bez wyłączeń): a11y obecne, a11y.md w grupie g-a11y', () => {
+  const sections = loadChecklistSections(CHECKLIST);
+  const groups = loadChecklistGroups(CHECKLIST);
+  assert.ok(sections.find(s => s.name.includes('a11y')), 'sekcja a11y obecna');
+  const a11yGroup = groups.find(g => g.id === 'g-a11y');
+  assert.ok(a11yGroup, 'grupa g-a11y obecna');
+  assert.ok(a11yGroup.standardFiles.includes('a11y.md'), 'a11y.md w standardach grupy');
+  // Indeksy sekcji są ciągłe 0..N-1 (suma po grupach pokrywa wszystkie).
+  assert.deepEqual(idxUnion(groups), sections.map((_, i) => i));
+});
+
+test('wyłączenie a11y: sekcja znika, a11y.md wypada, grupa g-a11y zostaje (ma i18n), reindeks ciągły', () => {
+  const disabled = ['a11y'];
+  const sections = loadChecklistSections(CHECKLIST, disabled);
+  const groups = loadChecklistGroups(CHECKLIST, disabled);
+  const baseline = loadChecklistSections(CHECKLIST);
+  assert.equal(sections.length, baseline.length - 1);
+  assert.equal(sections.find(s => s.name === 'Dostępność (a11y)'), undefined);
+  const a11yGroup = groups.find(g => g.id === 'g-a11y');
+  assert.ok(a11yGroup, 'g-a11y dalej istnieje (ma i18n)');
+  assert.equal(a11yGroup.standardFiles.includes('a11y.md'), false, 'a11y.md wypadł');
+  assert.ok(a11yGroup.standardFiles.includes('i18n.md'), 'i18n.md został');
+  // Reindeks: indeksy nadal ciągłe 0..N-1, bez dziur po usuniętej sekcji.
+  assert.deepEqual(idxUnion(groups), sections.map((_, i) => i));
+});
+
+test('wyłączenie a11y+i18n: grupa g-a11y opróżniona → wypuszczona', () => {
+  const disabled = ['a11y', 'i18n'];
+  const groups = loadChecklistGroups(CHECKLIST, disabled);
+  assert.equal(groups.find(g => g.id === 'g-a11y'), undefined, 'pusta grupa wypuszczona');
+  const baseGroups = loadChecklistGroups(CHECKLIST);
+  assert.equal(groups.length, baseGroups.length - 1);
+});
+
+test('wyłączenie sekcji critical → throw', () => {
+  assert.throws(() => loadChecklistSections(CHECKLIST, ['context']), /critical/i);
+});
+
+test('wyłączenie nieistniejącej sekcji → throw', () => {
+  assert.throws(() => loadChecklistSections(CHECKLIST, ['nope']), /nieistniejącą sekcję/);
+});
