index 0000000..bb28a36
--- /dev/null
+++ b/.github/scripts/pipeline-scope.js
@@ -0,0 +1,95 @@
+/**
+ * PIPELINE SCOPE — globalne wyłączanie WARSTW / SEKCJI / STANDARDÓW z pipeline'u.
+ *
+ * SSOT konfiguracji: PROJECT.pipelineScope (global-config). Ten moduł NIE czyta
+ * configu (żeby nie tworzyć cyklu z global-config) — dostaje surowy obiekt scope
+ * + słownik warstw JAWNIE i zwraca ROZWIĄZANY, zwalidowany zakres z predykatami.
+ *
+ * Trzy NIEZALEŻNE osie (decyzja projektowa — bez auto-mapowania warstwa↔sekcja):
+ *   - disabledLayers    → oś A, wchodzi w DEKOMPOZYTORZE (filtr grafu story-layers.yaml);
+ *                         architekt/planner/coder czytają przefiltrowany artefakt → 0 zmian.
+ *   - disabledSections  → oś B1, wchodzi w CLARIFIERZE (sekcje DoR z story-readiness.yaml);
+ *                         walidacja "nie wolno critical" żyje w sections-loader (tam jest flaga).
+ *   - disabledStandards → oś B2, wchodzi w PLANNERZE (pliki .md out z task.standards[]).
+ *
+ * PRESETY: `apply: [...]` rozwija nazwane presety i robi UNIĘ z jawnymi listami
+ * (dedup). Jeden punkt rozwiązania → reszta pipeline'u czyta wyłącznie wynik.
+ *
+ * NIEZMIENNIK: każdy przełącznik aktywuje się na SWOIM etapie, więc po zmianie
+ * trzeba RE-RUN OD TEGO ETAPU w górę (cache spójny dzięki kaskadowemu purge
+ * orchestratora).
+ */
+
+const asArray = (v) => (Array.isArray(v) ? v.map(String) : []);
+const uniqSorted = (arr) => [...new Set(arr)].sort();
+
+/**
+ * Rozwiązuje i waliduje zakres pipeline'u.
+ *
+ * @param {object} scope                  — PROJECT.pipelineScope (lub {})
+ * @param {string[]} [scope.apply]        — nazwy aktywnych presetów
+ * @param {string[]} [scope.disabledLayers]
+ * @param {string[]} [scope.disabledSections]
+ * @param {string[]} [scope.disabledStandards]
+ * @param {Object<string,object>} [scope.presets]
+ * @param {string[]} [layerVocabulary]    — dozwolone nazwy warstw (Object.keys(layerToBucket));
+ *                                          gdy podane, warstwa spoza słownika = throw (fail-fast).
+ * @returns {Readonly<{
+ *   layers: string[], sections: string[], standards: string[],
+ *   isLayerDisabled: (id:string)=>boolean,
+ *   isSectionDisabled: (id:string)=>boolean,
+ *   isStandardDisabled: (file:string)=>boolean,
+ *   isEmpty: boolean,
+ * }>}
+ */
+export function resolvePipelineScope(scope = {}, layerVocabulary = []) {
+  const presets = scope?.presets ?? {};
+  const apply = asArray(scope?.apply);
+
+  // Nieznany preset = błąd konfiguracji (literówka cicho gubiłaby intencję).
+  for (const name of apply) {
+    if (!Object.prototype.hasOwnProperty.call(presets, name)) {
+      throw new Error(
+        `pipeline-scope: nieznany preset "${name}" w \`apply\` ` +
+        `(dostępne: ${Object.keys(presets).join(', ') || 'brak'})`,
+      );
+    }
+  }
+
+  // Unia jawnej listy z polami `field` wszystkich aktywnych presetów.
+  const merge = (field) => uniqSorted([
+    ...asArray(scope?.[field]),
+    ...apply.flatMap((name) => asArray(presets[name]?.[field])),
+  ]);
+
+  const layers = merge('disabledLayers');
+  const sections = merge('disabledSections');
+  const standards = merge('disabledStandards');
+
+  // Walidacja warstw względem słownika (sekcje walidowane w sections-loader — tam
+  // jest `critical`; standardy nie walidujemy twardo, bo lista plików bywa luźna).
+  if (layerVocabulary.length > 0) {
+    const vocab = new Set(layerVocabulary);
+    const unknown = layers.filter((l) => !vocab.has(l));
+    if (unknown.length > 0) {
+      throw new Error(
+        `pipeline-scope: warstwa(y) spoza słownika w disabledLayers: ${unknown.join(', ')} ` +
+        `(dozwolone: ${layerVocabulary.join(', ')})`,
+      );
+    }
+  }
+
+  const layerSet = new Set(layers);
+  const sectionSet = new Set(sections);
+  const standardSet = new Set(standards);
+
+  return Object.freeze({
+    layers,
+    sections,
+    standards,
+    isLayerDisabled: (id) => layerSet.has(id),
+    isSectionDisabled: (id) => sectionSet.has(id),
+    isStandardDisabled: (file) => standardSet.has(file),
+    isEmpty: layers.length === 0 && sections.length === 0 && standards.length === 0,
+  });
+}
