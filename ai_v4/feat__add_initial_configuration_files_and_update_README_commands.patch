--- /dev/null	(date 1784588184647)
+++ b/tools/eslint-rules/library-naming/library-naming.ts	(date 1784588184647)
@@ -0,0 +1,93 @@
+import { existsSync } from 'fs';
+// Importy nazwane, nie domyślne: ten projekt kompiluje się bez `esModuleInterop`,
+// więc `import path from 'path'` dałoby `undefined`.
+import { dirname, join, relative, sep } from 'path';
+
+import { ESLintUtils } from '@typescript-eslint/utils';
+
+import { checkApplicationProject, checkLibraryProject, collectAliases } from '../../../scripts/validators/library-naming-validator.js';
+
+/**
+ * Reguła: nazwa projektu, alias importu i tagi muszą zgadzać się z katalogiem,
+ * w którym projekt leży.
+ *
+ * Wisi na `project.json`, bo sprawdzenie dotyczy PROJEKTU, nie pojedynczego pliku
+ * źródłowego. Biblioteki sprawdzane są w komplecie (nazwa, tagi, alias),
+ * aplikacje pod kątem nazwy, tagów i zadeklarowanego prefiksu.
+ *
+ * Samo sprawdzenie mieszka w `scripts/validators/library-naming-validator.js`
+ * i jest współdzielone z przeglądem całego repozytorium
+ * (`npm run validate:library-naming`), więc obie drogi zgłaszają to samo.
+ *
+ * Jedno sprawdzenie zostaje poza regułą: alias, którego nie żąda żadna biblioteka.
+ * Wymaga spojrzenia na wszystkie projekty naraz, a reguła widzi jeden plik.
+ */
+// NOTE: The rule will be available in ESLint configs as "@nx/workspace-library-naming"
+export const RULE_NAME = 'library-naming';
+
+export const rule = ESLintUtils.RuleCreator(() => __filename)({
+  name: RULE_NAME,
+  meta: {
+    type: 'problem',
+    docs: {
+      description: 'Nazwa projektu, alias importu i tagi zgadzają się z położeniem katalogu.',
+    },
+    schema: [],
+    messages: {
+      namingMismatch: 'Nazewnictwo projektu: {{note}} [{{kind}}]',
+    },
+  },
+  defaultOptions: [],
+  create(context) {
+    return {
+      Program(node): void {
+        const directory = dirname(context.filename);
+        const root = findWorkspaceRoot(directory);
+        if (!root) return; // poza repozytorium nie ma z czym porównywać
+
+        let projectJson: { name?: string; projectType?: string; tags?: string[]; prefix?: string };
+        try {
+          projectJson = JSON.parse(context.sourceCode.getText());
+        } catch {
+          return; // niepoprawny JSON zgłasza parser, nie ta reguła
+        }
+
+        const relativeDirectory = relative(root, directory).split(sep).join('/');
+        let violations: Array<{ kind: string; note: string }> = [];
+
+        if (projectJson?.projectType === 'library') {
+          violations = checkLibraryProject({
+            directory: relativeDirectory,
+            projectJson,
+            aliases: collectAliases(root),
+            naming: { root },
+          });
+        } else if (projectJson?.projectType === 'application') {
+          violations = checkApplicationProject({ directory: relativeDirectory, projectJson });
+        } else {
+          return;
+        }
+
+        for (const violation of violations) {
+          context.report({
+            node,
+            messageId: 'namingMismatch',
+            data: { note: violation.note, kind: violation.kind },
+          });
+        }
+      },
+    };
+  },
+});
+
+/** Korzeń repozytorium = najbliższy katalog w górę, w którym leży tsconfig.base.json. */
+function findWorkspaceRoot(from: string): string | null {
+  let current = from;
+
+  for (;;) {
+    if (existsSync(join(current, 'tsconfig.base.json'))) return current;
+    const parent = dirname(current);
+    if (parent === current) return null;
+    current = parent;
+  }
+}
