+import { ESLintUtils } from '@typescript-eslint/utils';
+
+import { checkTagCoverage } from '../../../scripts/validators/boundary-tags-validator.js';
+
+/**
+ * Reguła: każdy tag postawiony na projekcie musi mieć regułę w `depConstraints`.
+ *
+ * Tag spoza tej listy nie jest luźniejszy — jest niewidzialny. Projekt mający
+ * tylko takie tagi nie ma żadnych ograniczeń zależności, a granice modułów nie
+ * powiedzą o tym słowa.
+ *
+ * Reguły granic dostaje przez opcję, a nie przez wczytanie konfiguracji ESLinta:
+ * konfiguracja jest tym, co ładuje tę regułę, więc sięganie do niej byłoby
+ * zależnością w kółko. W `eslint.config.mjs` obie reguły biorą tę samą stałą.
+ *
+ * Sprawdzenie mieszka w `scripts/validators/boundary-tags-validator.js` i jest
+ * współdzielone z przeglądem całego repozytorium (`npm run validate:boundary-tags`).
+ * Druga strona relacji — tag wymieniony w regułach, którego nie nosi żaden projekt —
+ * zostaje wyłącznie tam, bo wymaga spojrzenia na wszystkie projekty naraz.
+ */
+// NOTE: The rule will be available in ESLint configs as "@nx/workspace-boundary-tags"
+export const RULE_NAME = 'boundary-tags';
+
+type Options = [{ depConstraints?: unknown[] }];
+
+export const rule = ESLintUtils.RuleCreator(() => __filename)<Options, 'tagWithoutRule'>({
+  name: RULE_NAME,
+  meta: {
+    type: 'problem',
+    docs: {
+      description: 'Każdy tag projektu ma odpowiadającą regułę w @nx/enforce-module-boundaries.',
+    },
+    schema: [
+      {
+        type: 'object',
+        properties: {
+          depConstraints: { type: 'array' },
+        },
+        additionalProperties: false,
+      },
+    ],
+    messages: {
+      tagWithoutRule: 'Tag bez reguły granic: {{note}}',
+    },
+  },
+  defaultOptions: [{ depConstraints: [] }],
+  create(context, [options]) {
+    return {
+      Program(node): void {
+        let projectJson: { name?: string; tags?: string[] };
+        try {
+          projectJson = JSON.parse(context.sourceCode.getText());
+        } catch {
+          return; // niepoprawny JSON zgłasza parser, nie ta reguła
+        }
+
+        if (!Array.isArray(projectJson?.tags) || projectJson.tags.length === 0) return;
+
+        const violations = checkTagCoverage({
+          projects: [{ project: projectJson.name ?? context.filename, tags: projectJson.tags }],
+          depConstraints: options.depConstraints ?? [],
+        });
+
+        for (const violation of violations) {
+          // Same błędy: przy jednym projekcie każdy tag z reguł, którego akurat
+          // nie nosi, wyglądałby na nieużywany — a to pytanie o cały workspace.
+          if (violation.severity !== 'error') continue;
+          context.report({ node, messageId: 'tagWithoutRule', data: { note: violation.note } });
+        }
+      },
+    };
+  },
+});
