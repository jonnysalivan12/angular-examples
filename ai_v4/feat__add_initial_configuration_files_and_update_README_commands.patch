@@ -0,0 +1,77 @@
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Biblioteki — fakty o tym repozytorium: jakie typy istnieją, jak się je zapisuje
+ * i skąd derywuje się nazwa, katalog oraz alias.
+ *
+ * To JEDYNE miejsce z tymi wartościami. Przed dodaniem stałej sprawdź, czy nie
+ * stoi już tutaj — trzy kopie listy typów, każda w innej kolejności, były powodem
+ * powstania tego katalogu.
+ *
+ * Adaptacja do innego repozytorium = edycja tego pliku, bez dotykania kodu.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+/**
+ * Typy bibliotek — oś `type:` konfiguracji granic zależności.
+ *
+ * Lustrzane z regułami `type:*` w `eslint.dep-constraints.mjs`: nowy typ wymaga
+ * wpisu tam i tutaj w jednym pull requeście, inaczej biblioteka nowego typu
+ * powstanie bez żadnych ograniczeń zależności.
+ */
+export const LIBRARY_TYPES = Object.freeze(['feature', 'ui', 'state', 'core', 'model', 'util', 'asset']);
+
+/** Typy występujące WYŁĄCZNIE jako barrel typu w kontekście — bez segmentu nazwy. */
+export const BARREL_ONLY_TYPES = Object.freeze(['asset', 'model', 'util']);
+
+/**
+ * Typy bez kodu Angulara — powstają kolekcją `@nx/js:library`, która nie przyjmuje
+ * `--prefix`, `--standalone` ani `--skipModule`. Pozostałe niosą prefiks selektora,
+ * więc powstają kolekcją `@nx/angular:library`.
+ */
+export const JS_LIBRARY_TYPES = Object.freeze(['asset']);
+
+/**
+ * Osie tagów, które MUSI nieść każdy projekt: klucz to nazwa osi, wartość to
+ * przedrostek taga w `project.json`.
+ *
+ * Nazwy osi są takie jak w repozytorium — `context`, nie `domain`. Plany agentów
+ * używają dla tych samych osi własnych nazw (`tag` zamiast `type`, `domain`
+ * zamiast `context`); tłumaczenie należy do granicy z planem, nie tutaj.
+ *
+ * Lustrzane z `sourceTag` w `eslint.dep-constraints.mjs` — reguła granic liczy
+ * zależności wyłącznie z tagów o tych przedrostkach.
+ */
+export const TAG_AXES = Object.freeze({
+  scope: 'scope:',
+  type: 'type:',
+  context: 'context:',
+});
+
+/** Sufiks katalogu projektu testów przeglądarkowych — rządzi się własnym typem. */
+export const E2E_PROJECT_SUFFIX = '-e2e';
+
+/**
+ * Konwencja nazewnictwa bibliotek. Z tych wartości deterministycznie derywuje się
+ * nazwa projektu nx, katalog i alias importu z trójki (scope, type, context) —
+ * patrz `scripts/generators/utils/library-naming.js`.
+ *
+ * Model app-agnostyczny: monorepo może mieć wiele aplikacji, więc prefiks aliasu
+ * i selektora NIE jest globalną stałą — to jeden identyfikator per cel
+ * (alias === selektor). Wszystkie ścieżki liczone od korzenia repozytorium.
+ */
+export const LIBRARY_NAMING = Object.freeze({
+  /** Scope bibliotek reużywalnych; ich katalogi żyją w `sharedBase`, poza apps/<app>. */
+  sharedScope: 'shared',
+
+  /** Wspólny prefiks WSZYSTKICH bibliotek reużywalnych (alias i selektor naraz).
+   *  Prefiksy bibliotek app-owych nie stoją tutaj — deklaruje je pole `prefix`
+   *  w `apps/<scope>/project.json`, czytane z workspace przy derywacji. */
+  sharedPrefix: 'gdprrt',
+
+  /** Korzeń bibliotek przypisanych do aplikacji. */
+  appsBase: 'libs/apps',
+
+  /** Korzeń bibliotek reużywalnych. */
+  sharedBase: 'libs/shared',
+
+  /** Korzeń projektów aplikacji (nx `workspaceLayout.appsDir`) — stąd czytany jest prefiks. */
+  appProjectsBase: 'apps',
+});
