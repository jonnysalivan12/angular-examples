+import assert from 'node:assert/strict';
+import { test } from 'node:test';
+
+import { DEP_CONSTRAINTS } from '../../eslint.dep-constraints.mjs';
+import { BARREL_ONLY_TYPES, JS_LIBRARY_TYPES, LIBRARY_TYPES, TAG_AXES } from './library.js';
+
+/* ── spójność wewnątrz konfiguracji ────────────────────────────────────────── */
+
+test('podzbiory typów wskazują na typy, które istnieją', () => {
+  for (const type of [...BARREL_ONLY_TYPES, ...JS_LIBRARY_TYPES]) {
+    assert.ok(LIBRARY_TYPES.includes(type), `"${type}" nie jest typem biblioteki`);
+  }
+});
+
+test('wartości są zamrożone — konsument ich nie zmutuje', () => {
+  assert.ok(Object.isFrozen(LIBRARY_TYPES));
+  assert.ok(Object.isFrozen(BARREL_ONLY_TYPES));
+  assert.ok(Object.isFrozen(TAG_AXES));
+});
+
+/* ── lustro w kodzie: reguły granic ────────────────────────────────────────── */
+
+test('każdy typ biblioteki ma regułę granic', () => {
+  const sourceTags = new Set(DEP_CONSTRAINTS.map((constraint) => constraint.sourceTag));
+
+  for (const type of LIBRARY_TYPES) {
+    const tag = `${TAG_AXES.type}${type}`;
+    assert.ok(
+      sourceTags.has(tag),
+      `typ "${type}" nie ma reguły "${tag}" w eslint.dep-constraints.mjs — biblioteka tego typu ` +
+        'powstałaby bez żadnych ograniczeń zależności',
+    );
+  }
+});
+
+test('każda reguła osi type: wskazuje na istniejący typ', () => {
+  const zReguł = DEP_CONSTRAINTS.map((constraint) => constraint.sourceTag)
+    .filter((tag) => typeof tag === 'string' && tag.startsWith(TAG_AXES.type))
+    .map((tag) => tag.slice(TAG_AXES.type.length));
+
+  for (const type of zReguł) {
+    // `app` i `e2e` to typy PROJEKTÓW, nie bibliotek — nie stoją w LIBRARY_TYPES.
+    if (type === 'app' || type === 'e2e') continue;
+    assert.ok(LIBRARY_TYPES.includes(type), `reguła granic zna typ "${type}", którego nie ma w konfiguracji`);
+  }
+});
