+import assert from 'node:assert/strict';
+import { test } from 'node:test';
+
+import { deriveLibraryNaming } from './library-naming.js';
+
+/**
+ * Prefiksy podstawione wprost, żeby derywacja nie schodziła po nie na dysk.
+ * Wartości są zmyślone, a nie wzięte z tego repozytorium: sprawdzany jest kształt
+ * derywacji, ten sam w każdym workspace, więc zmiana prefiksu w konfiguracji
+ * nie ma tu niczego przewracać.
+ */
+const NAMING = { sharedPrefix: 'acme', prefixByScope: { web: 'acme-web' } };
+
+test('dialekt repozytorium: scope/type/context/name', () => {
+  const canonical = deriveLibraryNaming({ scope: 'shared', type: 'ui', context: 'auth', name: 'button' }, NAMING);
+
+  assert.deepEqual(canonical, {
+    name: 'shared-auth-ui-button',
+    directory: 'libs/shared/auth/ui/button',
+    importPath: '@acme/shared/auth/ui/button',
+    selectorPrefix: 'acme',
+  });
+});
+
+test('dialekt planu agentów daje identyczny wynik', () => {
+  const zRepo = deriveLibraryNaming({ scope: 'web', type: 'feature', context: 'auth', name: 'login' }, NAMING);
+  const zPlanu = deriveLibraryNaming({ scope: 'web', tag: 'feature', domain: 'auth', segment: 'login' }, NAMING);
+
+  assert.deepEqual(zPlanu, zRepo);
+});
+
+test('dialekt repozytorium ma pierwszeństwo przed aliasem planu', () => {
+  const canonical = deriveLibraryNaming({ scope: 'shared', type: 'ui', tag: 'core', context: 'auth', domain: 'inny' }, NAMING);
+
+  assert.equal(canonical.directory, 'libs/shared/auth/ui');
+});
+
+test('brak typu w OBU dialektach → null, bo nie ma z czego derywować', () => {
+  assert.equal(deriveLibraryNaming({ scope: 'shared', context: 'auth' }, NAMING), null);
+  assert.equal(deriveLibraryNaming({ scope: 'shared', domain: 'auth' }, NAMING), null);
+});
+
+test('biblioteka-barrel: bez nazwy po typie, w obu dialektach', () => {
+  const zRepo = deriveLibraryNaming({ scope: 'shared', type: 'util', context: 'common' }, NAMING);
+  const zPlanu = deriveLibraryNaming({ scope: 'shared', tag: 'util', domain: 'common' }, NAMING);
+
+  assert.equal(zRepo.name, 'shared-common-util');
+  assert.deepEqual(zPlanu, zRepo);
+});
