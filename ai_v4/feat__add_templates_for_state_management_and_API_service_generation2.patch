-/**
- * Parsuje alias do {prefix, scope, context, type, name} wg jednej z dwóch gramatyk.
- * Dyskryminator: prefix === sharedPrefix → reużywalna (scope jest segmentem),
- * inaczej → app-owa (apka w prefiksie, brak segmentu scope; kontekst pierwszy).
- *
- *   reużywalna: @<sharedPrefix>/<scope>/<kontekst>/<type>[/<name>]  (3–4 segmenty po prefiksie)
- *   app-owa:    @<prefix>/<kontekst>/<type>[/<name>]                 (2–3 segmenty po prefiksie)
- *
- * @returns {{prefix:string, scope:string|null, context:string, type:string, name:string|null}|null}
- *          null gdy alias nie pasuje do żadnej gramatyki (→ alias-format-invalid).
- */
-function parseAlias(alias, sharedPrefix, sharedScope) {
-  const m = alias.match(/^@([^/]+)\/(.+)$/);
-  if (!m) return null;
-  const prefix = m[1];
-  const tail = m[2].split('/').filter(Boolean);
-  if (tail.length === 0) return null;
-
-  if (prefix === sharedPrefix) {
-    // reużywalna: <scope>/<kontekst>/<type>[/<name>] — wymaga ≥3 segmentów
-    if (tail.length < 3 || tail.length > 4) return null;
-    return { prefix, scope: tail[0], context: tail[1], type: tail[2], name: tail[3] ?? null };
-  }
-  // app-owa: <kontekst>/<type>[/<name>] — apka jest w prefiksie
-  if (tail.length < 2 || tail.length > 3) return null;
-  return { prefix, scope: null, context: tail[0], type: tail[1], name: tail[2] ?? null };
-}
-
-function parseJsonStripComments(text) {
-  // Minimalne stripping komentarzy // i /* */ dla tsconfig.json
-  const stripped = text
-    .replace(/\/\*[\s\S]*?\*\//g, '')
-    .replace(/\/\/.*$/gm, '');
-  return JSON.parse(stripped);
-}
-
-function parseArgs(argv) {
-  const args = {};
-  for (const a of argv) {
-    const m = a.match(/^--([^=]+)(?:=(.*))?$/);
-    if (m) args[m[1]] = m[2] || true;
-  }
-  return args;
-}
-
-function fail(msg) {
-  process.stderr.write(`naming-validator: ${msg}\n`);
-  process.exit(2);
-}
-
-function printHuman({ aliases_checked, directories_checked, violations_count, violations }) {
-  console.log(`naming-validator — checked ${aliases_checked} aliases, ${directories_checked} library directories`);
-  if (violations_count === 0) {
-    console.log('✓ No violations found.');
-    return;
-  }
-  console.log(`✗ ${violations_count} violation(s):\n`);
-  for (const v of violations) {
-    const head = `[${v.kind}]`;
-    const subject = v.alias || v.directory || '?';
-    console.log(`  ${head} ${subject}`);
-    if (v.note) console.log(`    ${v.note}`);
-    if (v.target) console.log(`    → target: ${v.target}`);
-    if (v.should_be) console.log(`    → should be: ${v.should_be}`);
-    console.log();
-  }
-}
