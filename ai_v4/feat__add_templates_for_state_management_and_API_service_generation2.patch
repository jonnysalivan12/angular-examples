+#!/usr/bin/env node
+import { readFileSync, existsSync, readdirSync } from 'fs';
+import path from 'path';
+import { pathToFileURL } from 'url';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Readme validator — sprawdza, czy każda biblioteka ma wypełniony README
+ * z blokiem metadanych, i wypisuje te, które go nie mają.
+ *
+ * Biblioteka = katalog pod `libs/` z plikiem `project.json`.
+ *
+ * Oczekiwany kształt README (produkuje go umiejętność nx-library-descriptor):
+ *
+ *   # Biblioteka <Nazwa>
+ *
+ *   ## Metadata
+ *
+ *   ```yaml
+ *   name: <nazwa projektu nx>
+ *   description: >
+ *     Co biblioteka robi i do czego służy.
+ *   status: active
+ *   ```
+ *
+ * Wykrywane naruszenia:
+ *   1. readme-missing      — brak README.md w katalogu biblioteki
+ *   2. metadata-missing    — README bez bloku ```yaml z metadanymi
+ *   3. field-missing       — brak pola name/description/status
+ *   4. description-empty   — pole description puste albo samo wypełnienie wzorca
+ *   5. status-invalid      — status spoza dozwolonych wartości
+ *   6. name-mismatch       — name w metadanych ≠ name w project.json
+ *
+ * Exit code: 0 gdy zero naruszeń, 1 gdy są (do CI).
+ * Zero zależności poza fs+path — narzędzie ma działać samodzielnie.
+ *
+ * Użycie:
+ *   node scripts/validators/readme-validator.js [--format=human|json] [--root=.]
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const REQUIRED_FIELDS = ['name', 'description', 'status'];
+const ALLOWED_STATUSES = ['active', 'maintenance', 'deprecated', 'experimental'];
+
+/** Tekst, który został z szablonu zamiast prawdziwego opisu. */
+const PLACEHOLDER_PATTERN = /^(\[|<|TODO|TBD|opis|description)/i;
+
+/**
+ * Wyciąga pola z pierwszego bloku ```yaml w treści README.
+ * Obsługuje wartości w jednej linii oraz wieloliniowe (`>`, `|`).
+ * @param {string} readmeText
+ * @returns {Record<string, string>|null} null gdy bloku nie ma
+ */
+export function parseMetadataBlock(readmeText) {
+  const block = /```yaml\r?\n([\s\S]*?)```/.exec(String(readmeText ?? ''));
+  if (!block) return null;
+
+  const lines = block[1].split(/\r?\n/);
+  const fields = {};
+  let index = 0;
+
+  while (index < lines.length) {
+    const declaration = /^([A-Za-z_][\w-]*):\s*(.*)$/.exec(lines[index]);
+    if (!declaration) {
+      index += 1;
+      continue;
+    }
+
+    const key = declaration[1];
+    const inlineValue = declaration[2].trim();
+    const isMultiline = inlineValue === '' || /^[|>][-+]?$/.test(inlineValue);
+
+    if (!isMultiline) {
+      fields[key] = inlineValue;
+      index += 1;
+      continue;
+    }
+
+    // Wartość wieloliniowa: kolejne wcięte linie należą do tego pola.
+    const collected = [];
+    index += 1;
+    while (index < lines.length && (lines[index].trim() === '' || /^\s/.test(lines[index]))) {
+      collected.push(lines[index].trim());
+      index += 1;
+    }
+    fields[key] = collected.filter(Boolean).join(' ').trim();
+  }
+
+  return fields;
+}
+
+/**
+ * Sprawdza README pojedynczej biblioteki.
+ * @param {object} args
+ * @param {string} args.projectName — nazwa z project.json
+ * @param {string} args.directory — katalog biblioteki (do raportu)
+ * @param {string|null} args.readmeText — treść README albo null, gdy pliku nie ma
+ * @returns {Array<{kind: string, library: string, directory: string, note: string}>}
+ */
+export function checkReadme({ projectName, directory, readmeText }) {
+  const violation = (kind, note) => ({ kind, library: projectName, directory, note });
+
+  if (readmeText === null || readmeText === undefined) {
+    return [violation('readme-missing', 'Brak pliku README.md w katalogu biblioteki.')];
+  }
+
+  const fields = parseMetadataBlock(readmeText);
+  if (!fields) {
+    return [violation('metadata-missing', 'README nie ma bloku ```yaml z polami name, description i status.')];
+  }
+
+  const violations = [];
+
+  for (const field of REQUIRED_FIELDS) {
+    if (fields[field] === undefined) {
+      violations.push(violation('field-missing', `Brak pola "${field}" w metadanych.`));
+    }
+  }
+
+  const description = (fields.description ?? '').trim();
+  if (fields.description !== undefined) {
+    if (description === '') {
+      violations.push(violation('description-empty', 'Pole description jest puste.'));
+    } else if (PLACEHOLDER_PATTERN.test(description)) {
+      violations.push(violation('description-empty', `Pole description zostało z szablonu: "${description.slice(0, 60)}".`));
+    }
+  }
+
+  if (fields.status !== undefined && !ALLOWED_STATUSES.includes(fields.status)) {
+    violations.push(violation('status-invalid', `Status "${fields.status}" spoza dozwolonych: ${ALLOWED_STATUSES.join(', ')}.`));
+  }
+
+  if (fields.name !== undefined && fields.name !== projectName) {
+    violations.push(violation('name-mismatch', `Metadane mówią "${fields.name}", a project.json "${projectName}".`));
+  }
+
+  return violations;
+}
+
+/* ── Powłoka CLI ───────────────────────────────────────────────────────────── */
+
+/** Katalogi bibliotek pod `libs/` — biblioteka = katalog z project.json. */
+function collectLibraries(libsRoot) {
+  const results = [];
+
+  function walk(directory) {
+    let entries;
+    try {
+      entries = readdirSync(directory, { withFileTypes: true });
+    } catch {
+      return;
+    }
+
+    if (entries.some((entry) => entry.isFile() && entry.name === 'project.json')) {
+      results.push(directory);
+      return;
+    }
+
+    for (const entry of entries) {
+      if (!entry.isDirectory() || entry.name === 'node_modules' || entry.name.startsWith('.')) continue;
+      walk(path.join(directory, entry.name));
+    }
+  }
+
+  walk(libsRoot);
+  return results;
+}
+
+function parseArgs(argv) {
+  const args = {};
+  for (const token of argv) {
+    const match = /^--([\w-]+)(?:=(.*))?$/.exec(token);
+    if (match) args[match[1]] = match[2] ?? true;
+  }
+  return args;
+}
+
+function readIfExists(filePath) {
+  return existsSync(filePath) ? readFileSync(filePath, 'utf-8') : null;
+}
+
+function printHuman({ libraries_checked, violations }) {
+  console.log(`readme-validator — sprawdzono ${libraries_checked} bibliotek`);
+
+  if (violations.length === 0) {
+    console.log('✓ Każda biblioteka ma wypełniony README.');
+    return;
+  }
+
+  const byLibrary = new Map();
+  for (const item of violations) {
+    if (!byLibrary.has(item.library)) byLibrary.set(item.library, []);
+    byLibrary.get(item.library).push(item);
+  }
+
+  console.log(`✗ Biblioteki bez poprawnego README: ${byLibrary.size}\n`);
+  for (const [library, items] of byLibrary) {
+    console.log(`  ${library}  (${items[0].directory})`);
+    for (const item of items) console.log(`    - [${item.kind}] ${item.note}`);
+    console.log();
+  }
+}
+
+function main() {
+  const args = parseArgs(process.argv.slice(2));
+  const root = path.resolve(args.root || '.');
+  const format = args.format || 'human';
+
+  const libsRoot = path.join(root, 'libs');
+  if (!existsSync(libsRoot)) {
+    process.stderr.write(`readme-validator: brak libs/ w ${root}\n`);
+    process.exit(2);
+  }
+
+  const directories = collectLibraries(libsRoot);
+  const violations = [];
+
+  for (const directory of directories) {
+    const projectJson = JSON.parse(readFileSync(path.join(directory, 'project.json'), 'utf-8'));
+    violations.push(...checkReadme({
+      projectName: projectJson.name ?? path.basename(directory),
+      directory: path.relative(root, directory).split(path.sep).join('/'),
+      readmeText: readIfExists(path.join(directory, 'README.md')),
+    }));
+  }
+
+  const report = { root, libraries_checked: directories.length, violations_count: violations.length, violations };
+
+  if (format === 'json') console.log(JSON.stringify(report, null, 2));
+  else printHuman(report);
+
+  process.exit(violations.length === 0 ? 0 : 1);
+}
+
+// Powłoka rusza wyłącznie przy bezpośrednim uruchomieniu — import w teście
+// ma dać czyste funkcje, nie wywołać CLI i nie ubić procesu przez process.exit.
+if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
+  main();
+}
