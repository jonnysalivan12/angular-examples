+function normalizeOptionName(optionName) {
+  return optionName.replace(/-([a-z])/g, (_match, group) => group.toUpperCase());
+}
+
+function parseOptionValue(rawValue) {
+  if (rawValue === 'true') {
+    return true;
+  }
+
+  if (rawValue === 'false') {
+    return false;
+  }
+
+  return rawValue;
+}
+
+export function parseCommandLine(argv) {
+  let command;
+  const options = {};
+  const positionals = [];
+
+  for (let index = 0; index < argv.length; index += 1) {
+    const token = argv[index];
+
+    if (token.startsWith('--')) {
+      const rawName = token.slice(2);
+      const equalsSignIndex = rawName.indexOf('=');
+
+      if (equalsSignIndex !== -1) {
+        const optionName = normalizeOptionName(rawName.slice(0, equalsSignIndex));
+        const optionValue = rawName.slice(equalsSignIndex + 1);
+
+        options[optionName] = parseOptionValue(optionValue);
+        continue;
+      }
+
+      const optionName = normalizeOptionName(rawName);
+      const nextToken = argv[index + 1];
+
+      if (!nextToken || nextToken.startsWith('--')) {
+        options[optionName] = true;
+        continue;
+      }
+
+      options[optionName] = parseOptionValue(nextToken);
+      index += 1;
+      continue;
+    }
+
+    if (!command) {
+      command = token;
+      continue;
+    }
+
+    positionals.push(token);
+  }
+
+  return {
+    command,
+    options,
+    positionals,
+  };
+}
+
+export function printHelp() {
+  console.log('Generator CLI');
+  console.log('');
+  console.log('Option syntax: --name value or --name=value');
+  console.log('');
+  console.log('Commands:');
+  console.log('  init-state --name <name> [--path <path>] [--nested <true|false>]');
+  console.log('  add-state-action --name <action.name> [--path <state-folder>] [--with-payload <true|false>] [--with-effect <true|false>]');
+  console.log('  add-async-state-action --name <action.name> [--path <state-folder>] [--request-with-payload <true|false>] [--success-with-payload <true|false>] [--failure-with-payload <true|false>]');
