@@ -0,0 +1,57 @@
+import path from 'path';
+
+import { toAbsolutePath, walkFiles, writeNewFile } from '../utils/fs-utils.js';
+import { renderTemplateFile, resolveTemplateSegment } from '../utils/template.js';
+import { camelize, classify, dasherize } from '../utils/strings.js';
+import { LIBRARY_NAMING } from '../../utils/naming-config.js';
+
+export async function runInitState({ options, positionals }) {
+  const rawName = options.name || positionals[0];
+
+  if (!rawName || typeof rawName !== 'string') {
+    throw new Error('init-state requires --name <stateName>.');
+  }
+
+  const targetRootPath = toAbsolutePath(process.cwd(), options.path || process.cwd());
+  const templatesRootPath = path.join(import.meta.dirname, '..', 'templates', 'init-state');
+  const templateFiles = walkFiles(templatesRootPath);
+
+  // Domyślnie wierzchni segment drzewa szablonów (`__name@dasherize__/`) jest
+  // pomijany — pliki slice'a lądują bezpośrednio w --path (biblioteka dedykowana
+  // jednemu slice'owi już niesie nazwę stanu w katalogu). `--nested` przywraca
+  // podkatalog <path>/<nazwa>/ dla bibliotek mieszczących wiele slice'ów.
+  // Parser CLI normalizuje `--nested`/`--nested true` do boolean.
+  const useNestedLayout = options.nested === true;
+
+  // Prefiks reużywalnych libów (alias `@<sharedPrefix>/shared/...`) pochodzi z JEDYNEGO
+  // SSOT (global-config PROJECT.libraryNaming) — NIE hardcoduj w templejtach. CLI
+  // `--shared-prefix` pozwala nadpisać per-workspace bez ruszania configu.
+  const sharedPrefix = options.sharedPrefix || LIBRARY_NAMING.sharedPrefix;
+
+  const templateContext = {
+    name: rawName,
+    sharedPrefix,
+    camelize,
+    classify,
+    dasherize,
+  };
+
+  for (const templateFilePath of templateFiles) {
+    const relativeTemplatePath = path.relative(templatesRootPath, templateFilePath);
+    const templateSegments = relativeTemplatePath.split(path.sep);
+    const destinationSegments =
+      !useNestedLayout && templateSegments.length > 1 ? templateSegments.slice(1) : templateSegments;
+
+    const resolvedRelativePath = destinationSegments
+      .map((segment) => resolveTemplateSegment(segment, templateContext))
+      .join(path.sep);
+
+    const destinationFilePath = path.join(targetRootPath, resolvedRelativePath);
+    const renderedContent = renderTemplateFile(templateFilePath, templateContext);
+
+    await writeNewFile(destinationFilePath, renderedContent);
+  }
+
+  console.log('[generator-cli] init-state completed: ' + rawName);
+  console.log('[generator-cli] files written to: ' + targetRootPath);
+}
