+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { parseMetadataBlock, checkReadme } from './readme-validator.js';
+
+/** README w kształcie, który produkuje umiejętność opisująca biblioteki. */
+const POPRAWNY = `# Biblioteka Util
+
+## Metadata
+
+\`\`\`yaml
+name: shared-common-util
+description: >
+  Formatuje daty i liczby oraz przekształca tablice.
+  Udostępnia te operacje całej aplikacji.
+status: active
+\`\`\`
+
+## Tooling
+`;
+
+const kinds = (violations) => violations.map((violation) => violation.kind);
+
+/* ── parseMetadataBlock ────────────────────────────────────────────────────── */
+
+test('parseMetadataBlock: skleja wartość wieloliniową i czyta pola jednoliniowe', () => {
+  const fields = parseMetadataBlock(POPRAWNY);
+
+  assert.equal(fields.name, 'shared-common-util');
+  assert.equal(fields.status, 'active');
+  assert.equal(fields.description, 'Formatuje daty i liczby oraz przekształca tablice. Udostępnia te operacje całej aplikacji.');
+});
+
+test('parseMetadataBlock: wartość w jednej linii oraz blok `|`', () => {
+  const inline = parseMetadataBlock('```yaml\nname: x\ndescription: Robi jedno.\nstatus: active\n```');
+  assert.equal(inline.description, 'Robi jedno.');
+
+  const literal = parseMetadataBlock('```yaml\nname: x\ndescription: |\n  Pierwsza.\n  Druga.\nstatus: active\n```');
+  assert.equal(literal.description, 'Pierwsza. Druga.');
+});
+
+test('parseMetadataBlock: lista nie połyka kolejnego pola', () => {
+  const fields = parseMetadataBlock('```yaml\nname: x\nkeywords:\n  - a\n  - b\nstatus: active\n```');
+  assert.equal(fields.status, 'active');
+});
+
+test('parseMetadataBlock: brak bloku yaml → null', () => {
+  assert.equal(parseMetadataBlock('# Biblioteka bez metadanych\n\nProza.'), null);
+  assert.equal(parseMetadataBlock(''), null);
+});
+
+/* ── checkReadme ───────────────────────────────────────────────────────────── */
+
+const sprawdz = (readmeText, projectName = 'shared-common-util') =>
+  checkReadme({ projectName, directory: 'libs/shared/common/util', readmeText });
+
+test('checkReadme: poprawny README nie daje naruszeń', () => {
+  assert.deepEqual(sprawdz(POPRAWNY), []);
+});
+
+test('checkReadme: brak pliku → readme-missing', () => {
+  const violations = sprawdz(null);
+  assert.deepEqual(kinds(violations), ['readme-missing']);
+  assert.equal(violations[0].library, 'shared-common-util');
+  assert.equal(violations[0].directory, 'libs/shared/common/util');
+});
+
+test('checkReadme: README bez bloku metadanych → metadata-missing (przypadek biblioteki asset)', () => {
+  const violations = sprawdz('# Zasoby statyczne\n\nProza bez metadanych.\n');
+  assert.deepEqual(kinds(violations), ['metadata-missing']);
+});
+
+test('checkReadme: brakujące pola zgłaszane osobno', () => {
+  const violations = sprawdz('```yaml\nname: shared-common-util\n```');
+  assert.deepEqual(kinds(violations), ['field-missing', 'field-missing']);
+  assert.match(violations.map((v) => v.note).join(';'), /description/);
+  assert.match(violations.map((v) => v.note).join(';'), /status/);
+});
+
+test('checkReadme: pusty opis i opis zostawiony z szablonu', () => {
+  const pusty = sprawdz('```yaml\nname: shared-common-util\ndescription: >\nstatus: active\n```');
+  assert.deepEqual(kinds(pusty), ['description-empty']);
+
+  const zSzablonu = sprawdz('```yaml\nname: shared-common-util\ndescription: >\n  [1–3 zdania: co biblioteka robi]\nstatus: active\n```');
+  assert.deepEqual(kinds(zSzablonu), ['description-empty']);
+});
+
+test('checkReadme: status spoza listy oraz nazwa rozjechana z project.json', () => {
+  const zlyStatus = sprawdz('```yaml\nname: shared-common-util\ndescription: Robi jedno.\nstatus: gotowe\n```');
+  assert.deepEqual(kinds(zlyStatus), ['status-invalid']);
+
+  const zlaNazwa = sprawdz('```yaml\nname: util\ndescription: Robi jedno.\nstatus: active\n```');
+  assert.deepEqual(kinds(zlaNazwa), ['name-mismatch']);
+  assert.match(zlaNazwa[0].note, /"util".*"shared-common-util"/);
+});
+
+test('checkReadme: cztery dozwolone statusy przechodzą', () => {
+  for (const status of ['active', 'maintenance', 'deprecated', 'experimental']) {
+    const violations = sprawdz(`\`\`\`yaml\nname: shared-common-util\ndescription: Robi jedno.\nstatus: ${status}\n\`\`\``);
+    assert.deepEqual(violations, [], status);
+  }
+});
