+import fs from 'fs';
+import path from 'path';
+
+export async function ensureDirectory(directoryPath) {
+  await fs.promises.mkdir(directoryPath, { recursive: true });
+}
+
+export function walkFiles(rootDirectoryPath) {
+  const entries = fs.readdirSync(rootDirectoryPath, { withFileTypes: true });
+  const files = [];
+
+  for (const entry of entries) {
+    const entryPath = path.join(rootDirectoryPath, entry.name);
+
+    if (entry.isDirectory()) {
+      files.push(...walkFiles(entryPath));
+      continue;
+    }
+
+    files.push(entryPath);
+  }
+
+  return files;
+}
+
+export function toAbsolutePath(currentDirectoryPath, rawPath) {
+  if (!rawPath) {
+    return currentDirectoryPath;
+  }
+
+  if (path.isAbsolute(rawPath)) {
+    return path.normalize(rawPath);
+  }
+
+  return path.resolve(currentDirectoryPath, rawPath);
+}
+
+export async function writeNewFile(filePath, content) {
+  if (fs.existsSync(filePath)) {
+    throw new Error('Target file already exists: ' + filePath);
+  }
+
+  await ensureDirectory(path.dirname(filePath));
+  await fs.promises.writeFile(filePath, content, 'utf8');
+}
