-function toYaml(obj) {
-  // Minimalny YAML serializer — wystarczy dla naming-violations w system-constraints.yaml
-  // Nie używamy `yaml` package żeby utility był standalone (zero deps poza fs+path).
-  const indent = (s, n) => s.split('\n').map(l => ' '.repeat(n) + l).join('\n');
-  const escape = (s) => {
-    const str = String(s);
-    if (/[:#\n"\\]/.test(str) || str.startsWith('@') || str.startsWith('-')) {
-      return JSON.stringify(str);
-    }
-    return str;
-  };
-  function serialize(value, depth = 0) {
-    const pad = ' '.repeat(depth);
-    if (value === null || value === undefined) return 'null';
-    if (typeof value === 'number' || typeof value === 'boolean') return String(value);
-    if (typeof value === 'string') return escape(value);
-    if (Array.isArray(value)) {
-      if (value.length === 0) return '[]';
-      return '\n' + value.map(item => {
-        const s = serialize(item, depth + 2);
-        return s.startsWith('\n')
-          ? `${pad}-${s}`
-          : `${pad}- ${s}`;
-      }).join('\n');
-    }
-    if (typeof value === 'object') {
-      const keys = Object.keys(value);
-      if (keys.length === 0) return '{}';
-      return '\n' + keys.map(k => {
-        const s = serialize(value[k], depth + 2);
-        return s.startsWith('\n')
-          ? `${pad}${k}:${s}`
-          : `${pad}${k}: ${s}`;
-      }).join('\n');
-    }
-    return String(value);
-  }
-  return 'naming_validation:' + serialize(obj, 2) + '\n';
-}
