+import { toAbsolutePath } from '../utils/fs-utils.js';
+import { classify } from '../utils/strings.js';
+import {
+  updateActionFile,
+  updateStateFile,
+  updateEffectFileForSimpleAction,
+} from '../utils/state-file-utils.js';
+
+function toBoolean(value, defaultValue) {
+  if (value === undefined) {
+    return defaultValue;
+  }
+
+  if (typeof value === 'boolean') {
+    return value;
+  }
+
+  const normalized = String(value).trim().toLowerCase();
+  if (normalized === 'true' || normalized === '1') {
+    return true;
+  }
+
+  if (normalized === 'false' || normalized === '0') {
+    return false;
+  }
+
+  return defaultValue;
+}
+
+export async function runAddStateAction({ repoRoot, options, positionals }) {
+  const rawName = options.name || positionals[0];
+
+  if (!rawName || typeof rawName !== 'string') {
+    throw new Error('add-state-action requires --name <actionName>.');
+  }
+
+  const stateFolderPath = toAbsolutePath(process.cwd(), options.path || process.cwd());
+  const withPayload = toBoolean(options.withPayload !== undefined ? options.withPayload : positionals[1], false);
+  const withEffect = toBoolean(options.withEffect !== undefined ? options.withEffect : positionals[2], false);
+
+  const actionUpdateResult = await updateActionFile({
+    repoRoot,
+    stateFolderPath,
+    actionName: rawName,
+    withPayload,
+    payloadContent: options.payloadContent,
+    payloadImports: options.payloadImports,
+  });
+
+  const actionFullName = [actionUpdateResult.rootNamespaceName]
+    .concat(actionUpdateResult.actionNodeNames)
+    .map((segment) => classify(segment))
+    .join('.');
+
+  await updateStateFile({
+    repoRoot,
+    stateFolderPath,
+    withPayload,
+    actionFullName,
+    actionNodeNames: actionUpdateResult.actionNodeNames,
+    actionPayloadModelName: actionUpdateResult.actionPayloadModelName,
+    actionContent: options.content,
+  });
+
+  if (withEffect) {
+    await updateEffectFileForSimpleAction({
+      repoRoot,
+      stateFolderPath,
+      withPayload,
+      actionFullName,
+      actionNodeNames: actionUpdateResult.actionNodeNames,
+      actionPayloadModelName: actionUpdateResult.actionPayloadModelName,
+    });
+  }
+
+  console.log('[generator-cli] add-state-action completed: ' + rawName);
+  console.log('[generator-cli] state path: ' + stateFolderPath);
+}
