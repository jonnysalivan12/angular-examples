+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Library generator — JEDYNE źródło komendy `nx g` dla nowej biblioteki.
+ *
+ * Wejściem są pola semantyczne (scope/type/context[/name]); nazwa, katalog,
+ * alias i prefiks są w całości DERYWOWANE kanonem (../utils/library-naming.js),
+ * a tagi notacją nx (../utils/nx-tags.js). Każdy konsument — CLI dla człowieka,
+ * scaffold pipeline'u — składa komendę TYM modułem; nigdzie indziej nie
+ * wolno budować `nx g @nx/angular:library` ręcznie.
+ *
+ * Kolekcja wynika z TYPU biblioteki, nie z pytania do człowieka. Typy z
+ * `JS_LIBRARY_TYPES` nie zawierają kodu Angulara, więc powstają kolekcją
+ * `@nx/js:library`, która nie przyjmuje `--prefix`, `--standalone` ani
+ * `--skipModule`. Pozostałe typy niosą prefiks selektora zapisywany
+ * w project.json, więc powstają kolekcją `@nx/angular:library`.
+ *
+ * Reszta konfiguracji generatora (unitTestRunner, linter) pochodzi z `nx.json`
+ * (`generators['@nx/angular:library']`) — to SSOT repo dla domyślnych parametrów.
+ * Moduł podaje WYŁĄCZNIE to, co wynika z pól semantycznych, i niczego nie dubluje.
+ *
+ * Funkcje są czyste (I/O wstrzykiwane); powłokę CLI na końcu pliku uruchamia
+ * wyłącznie bezpośrednie wywołanie `node library/index.js`.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+import { execSync } from 'node:child_process';
+import fs from 'node:fs';
+import { pathToFileURL } from 'node:url';
+
+import { deriveLibraryNaming, isKnownScope, listAppScopes } from '../utils/library-naming.js';
+import { tagStrings } from '../utils/nx-tags.js';
+import { parseCommandLine } from '../ngxs/utils/arg-parser.js';
+
+const ANGULAR_COLLECTION = '@nx/angular:library';
+const JS_COLLECTION = '@nx/js:library';
+const TSCONFIG_BASE = 'tsconfig.base.json';
+
+/** Dozwolone typy bibliotek — oś `type:` konfiguracji granic. */
+export const LIBRARY_TYPES = ['feature', 'ui', 'state', 'core', 'model', 'util', 'asset'];
+
+/** Typy występujące WYŁĄCZNIE jako barrel typu w kontekście (bez segmentu nazwy). */
+export const BARREL_ONLY_TYPES = ['asset', 'model', 'util'];
+
+/**
+ * Typy bez kodu Angulara — `asset` udostępnia przez barrel wyłącznie zasoby
+ * statyczne (arkusze stylów z tokenami), więc nie ma komponentów, wstrzykiwania
+ * ani szablonów. Rozszerzenie listy o kolejny typ = jedna edycja tutaj.
+ */
+export const JS_LIBRARY_TYPES = ['asset'];
+
+/**
+ * Kolekcja generatora dla typu biblioteki.
+ * @param {string} type — typ z LIBRARY_TYPES
+ * @returns {string} identyfikator kolekcji nx
+ */
+export function collectionFor(type) {
+  return JS_LIBRARY_TYPES.includes(String(type ?? '').trim()) ? JS_COLLECTION : ANGULAR_COLLECTION;
+}
+
+/**
+ * Normalizuje ścieżkę do porównań: separatory na `/`, bez wiodącego `./`.
+ * nx zapisuje cele aliasu jako `./libs/...`, a kanon derywacji jako `libs/...` —
+ * bez tego poprawnie wygenerowana biblioteka byłaby odrzucana przez własną bramkę.
+ */
+function normalizePath(value) {
+  return String(value ?? '').replace(/\\/g, '/').replace(/^\.\//, '');
+}
+
+/**
+ * Walidacja pól semantycznych wejścia (kontrakt wejścia CLI; czysta — bez I/O,
+ * więc istnienie scope w workspace sprawdza osobno powłoka).
+ * @param {{scope?: string, type?: string, context?: string, name?: string}} input
+ * @returns {string[]} lista błędów — pusta gdy wejście poprawne
+ */
+export function validateLibraryInput(input = {}) {
+  const errors = [];
+  if (!String(input.scope ?? '').trim()) errors.push('brak --scope (shared albo nazwa aplikacji nx)');
+  const type = String(input.type ?? '').trim();
+  if (!type) {
+    errors.push(`brak --type (${LIBRARY_TYPES.join(' | ')})`);
+  } else if (!LIBRARY_TYPES.includes(type)) {
+    errors.push(`nieznany --type '${type}' (dozwolone: ${LIBRARY_TYPES.join(' | ')})`);
+  }
+  if (!String(input.context ?? '').trim()) {
+    errors.push('brak --context (kontekst z docs/standards/context.md; kod przekrojowy = common)');
+  }
+  if (String(input.name ?? '').trim() && BARREL_ONLY_TYPES.includes(type)) {
+    errors.push(`--name niedozwolone dla typu '${type}' — ${BARREL_ONLY_TYPES.join('/')} istnieją wyłącznie jako barrel typu w kontekście`);
+  }
+  return errors;
+}
+
+/**
+ * Buduje deterministyczną specyfikację generacji z pól semantycznych: kanoniczne
+ * nazewnictwo, tagi, polecenie generatora i przewidywany produkt.
+ *
+ * W kolekcji Angulara `--standalone=false --skipModule` daje PUSTĄ bibliotekę
+ * (project.json + index.ts): domyślnie generator wstawia placeholderowy komponent
+ * standalone jako entry point, a komponenty w tym repo dodaje osobny generator.
+ * Kolekcja JS tych flag nie zna i pustą bibliotekę tworzy sama.
+ *
+ * @param {{scope?: string, type?: string, context?: string, name?: string}} input
+ * @param {object} [naming] — override konwencji (testy bez I/O workspace)
+ * @returns {{name: string, directory: string, importPath: string, prefix: string, tags: string[], collection: string, command: string, args: string[], produces: string} | null}
+ *          null gdy brak scope/type — nie ma z czego wyderywować kanonu.
+ */
+export function librarySpec(input = {}, naming = {}) {
+  const canonical = deriveLibraryNaming(
+    { scope: input.scope, tag: input.type, domain: input.context, segment: input.name },
+    naming,
+  );
+  if (!canonical) return null;
+
+  const tags = tagStrings({ scope: input.scope, type: input.type, domain: input.context });
+  const collection = collectionFor(input.type);
+  const isAngular = collection === ANGULAR_COLLECTION;
+
+  const args = [
+    'nx', 'g', collection,
+    `--name=${canonical.name}`,
+    `--directory=${canonical.directory}`,
+    `--importPath=${canonical.importPath}`,
+  ];
+  if (isAngular) args.push(`--prefix=${canonical.selectorPrefix}`);
+  args.push(`--tags=${tags.join(',')}`);
+  if (isAngular) args.push('--standalone=false', '--skipModule');
+  args.push('--no-interactive');
+
+  return {
+    name: canonical.name,
+    directory: canonical.directory,
+    importPath: canonical.importPath,
+    prefix: canonical.selectorPrefix,
+    tags,
+    collection,
+    command: 'npx',
+    args,
+    produces: `${canonical.directory}/project.json`,
+  };
+}
+
+/** Polecenie generacji w formie do logu i do raportu odstępstw. */
+export function libraryCommandLine(spec) {
+  return `${spec.command} ${spec.args.join(' ')}`;
+}
+
+/**
+ * Weryfikacja PO generacji: czy na dysku powstało to, co obiecuje kanon.
+ *
+ * Bramka celowa, bo `nx` normalizuje nazwy po swojemu — biblioteka może powstać
+ * pod inną nazwą projektu niż kanoniczna, a repo-szeroki walidator nazw tego nie
+ * złapie (katalog i alias będą spójne ze sobą, tylko nie z kanonem).
+ *
+ * @param {object} spec — wynik librarySpec
+ * @param {object} args
+ * @param {(path: string) => object|null} args.readJson — null gdy plik nie istnieje/nieparsowalny
+ * @returns {{ok: boolean, findings: Array<{severity: string, message: string}>}}
+ */
+export function verifyGeneratedLibrary(spec, { readJson }) {
+  const findings = [];
+  const project = readJson(spec.produces);
+
+  if (!project) {
+    findings.push({ severity: 'error', message: `scaffold nie utworzył '${spec.produces}'` });
+    return { ok: false, findings };
+  }
+  if (project.name !== spec.name) {
+    findings.push({
+      severity: 'error',
+      message: `nazwa projektu '${project.name}' ≠ kanon '${spec.name}' — generator znormalizował ją po swojemu`,
+    });
+  }
+  const projectTags = project.tags ?? [];
+  const missingTags = spec.tags.filter((tag) => !projectTags.includes(tag));
+  if (missingTags.length > 0) {
+    findings.push({ severity: 'error', message: `brak tagów w project.json: ${missingTags.join(', ')} (bramka G2 liczy granice z tagów)` });
+  }
+
+  // Biblioteka buildable dostaje własny target `build` (ng-packagr) i kompiluje się
+  // osobno od aplikacji. Tutaj biblioteki wchodzą do builda aplikacji ze źródeł,
+  // więc target `build` w project.json oznacza bibliotekę wygenerowaną wbrew kanonowi.
+  if (project.targets?.build) {
+    findings.push({
+      severity: 'error',
+      message: `biblioteka ma target 'build' — w tym repozytorium żadna biblioteka nie jest buildable`,
+    });
+  }
+
+  const tsconfig = readJson(TSCONFIG_BASE);
+  const aliasTargets = tsconfig?.compilerOptions?.paths?.[spec.importPath];
+  if (!aliasTargets) {
+    findings.push({ severity: 'error', message: `brak aliasu '${spec.importPath}' w ${TSCONFIG_BASE}` });
+  } else if (!aliasTargets.some((target) => normalizePath(target).startsWith(normalizePath(spec.directory)))) {
+    findings.push({
+      severity: 'error',
+      message: `alias '${spec.importPath}' wskazuje '${aliasTargets.join(', ')}' zamiast katalogu '${spec.directory}'`,
+    });
+  }
+
+  return { ok: findings.every((finding) => finding.severity !== 'error'), findings };
+}
+
+/**
+ * Wykonuje generację biblioteki: idempotentnie (produkt istnieje → pominięte),
+ * potem weryfikuje wynik przeciw kanonowi.
+ *
+ * @param {object} args
+ * @param {object} args.spec — wynik librarySpec
+ * @param {(command: string) => Promise<{exitCode: number, output: string}>} args.execCommand
+ * @param {(path: string) => object|null} args.readJson
+ * @param {(message: string) => void} [args.onLog]
+ * @returns {Promise<{ok: boolean, skipped: boolean, findings: Array, output: string}>}
+ */
+export async function runLibraryGenerator({ spec, execCommand, readJson, onLog = () => {} }) {
+  // Idempotencja NIE jest zaufaniem: produkt mógł zostać po nieudanym podejściu
+  // albo powstać ręcznie, więc istniejący szkielet też przechodzi weryfikację.
+  if (readJson(spec.produces)) {
+    const existing = verifyGeneratedLibrary(spec, { readJson });
+    onLog(`scaffold pominięty — '${spec.produces}' już istnieje`
+      + (existing.ok ? ' i jest zgodny z kanonem' : `, ALE NIEZGODNY z kanonem (${existing.findings.length} ustaleń)`));
+    return { ok: existing.ok, skipped: true, findings: existing.findings, output: '' };
+  }
+
+  onLog(`scaffold: ${libraryCommandLine(spec)}`);
+  const result = await execCommand(libraryCommandLine(spec));
+  if (result.exitCode !== 0) {
+    return {
+      ok: false,
+      skipped: false,
+      findings: [{ severity: 'error', message: `generator zakończył się kodem ${result.exitCode}` }],
+      output: result.output,
+    };
+  }
+
+  const verdict = verifyGeneratedLibrary(spec, { readJson });
+  onLog(`scaffold: ${verdict.ok ? `'${spec.name}' zgodna z kanonem` : `NIEZGODNA z kanonem (${verdict.findings.length} ustaleń)`}`);
+  return { ok: verdict.ok, skipped: false, findings: verdict.findings, output: result.output };
+}
+
+/* ── Powłoka CLI (uruchamiana wyłącznie bezpośrednim `node library/index.js`) ── */
+
+function printUsage() {
+  console.log('Library generator CLI — uruchamiaj z korzenia repozytorium.');
+  console.log('');
+  console.log('Użycie:');
+  console.log('  node scripts/generators/library/index.js \\');
+  console.log('    --scope <shared|nazwa-apki> --type <typ> --context <kontekst> [--name <nazwa>] [--dry-run]');
+  console.log('');
+  console.log(`Typy: ${LIBRARY_TYPES.join(' | ')} (${BARREL_ONLY_TYPES.join('/')} — wyłącznie barrel, bez --name)`);
+  console.log(`Kolekcja wynika z typu: ${JS_LIBRARY_TYPES.join('/')} → @nx/js:library, pozostałe → @nx/angular:library.`);
+}
+
+async function main() {
+  const parsed = parseCommandLine(process.argv.slice(2));
+  const options = parsed.options;
+
+  if (options.help) {
+    printUsage();
+    return;
+  }
+
+  const input = { scope: options.scope, type: options.type, context: options.context, name: options.name };
+  const errors = validateLibraryInput(input);
+  if (errors.length === 0 && !isKnownScope(input.scope)) {
+    errors.push(`nieznany scope '${input.scope}' — dostępne: ${listAppScopes().join(', ')}`);
+  }
+  if (errors.length > 0) {
+    for (const message of errors) console.error('[library-generator] ' + message);
+    printUsage();
+    process.exitCode = 1;
+    return;
+  }
+
+  const spec = librarySpec(input);
+  console.log('[library-generator] name:       ' + spec.name);
+  console.log('[library-generator] directory:  ' + spec.directory);
+  console.log('[library-generator] importPath: ' + spec.importPath);
+  if (spec.collection === ANGULAR_COLLECTION) {
+    console.log('[library-generator] prefix:     ' + spec.prefix);
+  }
+  console.log('[library-generator] tags:       ' + spec.tags.join(','));
+  console.log('[library-generator] kolekcja:   ' + spec.collection);
+  console.log('[library-generator] command:    ' + libraryCommandLine(spec));
+
+  if (options.dryRun) {
+    console.log('[library-generator] dry-run — bez wykonania.');
+    return;
+  }
+
+  const execCommand = async (command) => {
+    try {
+      const output = execSync(command, { encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'] });
+      return { exitCode: 0, output };
+    } catch (error) {
+      return { exitCode: error.status ?? 1, output: `${error.stdout ?? ''}${error.stderr ?? ''}` };
+    }
+  };
+  const readJson = (filePath) => {
+    try {
+      return JSON.parse(fs.readFileSync(filePath, 'utf8'));
+    } catch {
+      return null;
+    }
+  };
+
+  const result = await runLibraryGenerator({
+    spec,
+    execCommand,
+    readJson,
+    onLog: (message) => console.log('[library-generator] ' + message),
+  });
+
+  if (result.output) console.log(result.output);
+  for (const finding of result.findings) {
+    console.error(`[library-generator] ${finding.severity}: ${finding.message}`);
+  }
+  if (!result.ok) process.exitCode = 1;
+}
+
+if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
+  await main();
+}
