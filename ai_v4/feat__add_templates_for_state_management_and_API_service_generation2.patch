-/**
- * Walk libs/ w poszukiwaniu katalogów bibliotek. Library = katalog zawierający `src/`.
- */
-function walkLibs(libsRoot, root) {
-  const results = [];
-  function walk(dir) {
-    let entries;
-    try {
-      entries = readdirSync(dir, { withFileTypes: true });
-    } catch {
-      return;
-    }
-    // Jeśli ten katalog zawiera src/ — to jest library root
-    const hasSrc = entries.some(e => e.isDirectory() && e.name === 'src');
-    if (hasSrc) {
-      results.push(dir);
-      // NIE walkuj dalej — nested libs to anti-pattern
-      return;
-    }
-    for (const e of entries) {
-      if (!e.isDirectory()) continue;
-      if (e.name === 'node_modules' || e.name.startsWith('.')) continue;
-      walk(path.join(dir, e.name));
-    }
-  }
-  walk(libsRoot);
-  return results;
-}
