+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { splitTags, tagStrings } from './nx-tags.js';
+
+test('CSV → lista tagów', () => {
+  assert.deepEqual(splitTags('scope:app,type:state,context:auth'), ['scope:app', 'type:state', 'context:auth']);
+});
+
+test('separator spacjowy i mieszany → ta sama lista', () => {
+  assert.deepEqual(splitTags('scope:app type:state'), ['scope:app', 'type:state']);
+  assert.deepEqual(splitTags('scope:app, type:state  context:auth'), ['scope:app', 'type:state', 'context:auth']);
+});
+
+test('tablica przechodzi wprost, elementy z CSV są rozbijane', () => {
+  assert.deepEqual(splitTags(['scope:app', 'type:state,context:auth']), ['scope:app', 'type:state', 'context:auth']);
+});
+
+test('puste wejścia → pusta lista', () => {
+  assert.deepEqual(splitTags(''), []);
+  assert.deepEqual(splitTags('  ,  '), []);
+  assert.deepEqual(splitTags(null), []);
+  assert.deepEqual(splitTags(undefined), []);
+  assert.deepEqual(splitTags([]), []);
+});
+
+test('tagStrings: obiekt tagów → notacja nx w stałej kolejności scope,type,context', () => {
+  assert.deepEqual(tagStrings({ scope: 'shared', type: 'ui', domain: 'auth' }), [
+    'scope:shared',
+    'type:ui',
+    'context:auth',
+  ]);
+});
+
+test('tagStrings: brakujące pola pomijane; brak obiektu → pusta lista', () => {
+  assert.deepEqual(tagStrings({ scope: 'shared' }), ['scope:shared']);
+  assert.deepEqual(tagStrings({}), []);
+  assert.deepEqual(tagStrings(null), []);
+});
