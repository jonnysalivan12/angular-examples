+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Tagi nx — wspólna normalizacja zapisu listy tagów.
+ *
+ * Zapis tagów bywa tablicą albo stringiem, a separatorem bywa przecinek lub
+ * spacja. Nx w `--tags` rozumie WYŁĄCZNIE CSV — każdy inny zapis ląduje
+ * w project.json jako JEDEN sklejony tag (np. ["scope:app type:state"]),
+ * niewidoczny dla bramek liczących granice z tagów. Jedno miejsce rozstrzyga,
+ * jak czytać ten zapis; konsumenci nie parsują go samodzielnie.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+/**
+ * Rozbija zapis tagów na listę pojedynczych tagów.
+ * @param {string[]|string|null|undefined} value — tablica tagów albo string
+ *   rozdzielany przecinkami i/lub białymi znakami (formy mieszane dozwolone)
+ * @returns {string[]} tagi bez pustych elementów, w kolejności zapisu
+ */
+export function splitTags(value) {
+  const raw = Array.isArray(value) ? value.join(',') : String(value ?? '');
+  return raw
+    .split(/[,\s]+/)
+    .map((part) => part.trim())
+    .filter((part) => part.length > 0);
+}
+
+/**
+ * Zamienia obiekt tagów biblioteki na listę stringów w notacji nx.
+ * Pole `domain` niesie kontekst (obszar jednej domeny biznesowej) i jest
+ * emitowane jako tag `context:` — klucz osi w konfiguracji granic.
+ * @param {{scope?: string, type?: string, domain?: string}} [tags]
+ * @returns {string[]} np. ['scope:shared', 'type:ui', 'context:common']
+ */
+export function tagStrings(tags) {
+  if (!tags || typeof tags !== 'object') return [];
+  const output = [];
+  if (tags.scope) output.push(`scope:${tags.scope}`);
+  if (tags.type) output.push(`type:${tags.type}`);
+  if (tags.domain) output.push(`context:${tags.domain}`);
+  return output;
+}
