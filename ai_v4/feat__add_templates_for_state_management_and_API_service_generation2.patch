+function splitIntoWords(value) {
+  return String(value)
+    .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
+    .replace(/[_.\-/]+/g, ' ')
+    .trim()
+    .split(/\s+/)
+    .filter(Boolean);
+}
+
+function capitalize(value) {
+  return value.charAt(0).toUpperCase() + value.slice(1).toLowerCase();
+}
+
+export function classify(value) {
+  return splitIntoWords(value).map(capitalize).join('');
+}
+
+export function camelize(value) {
+  const words = splitIntoWords(value);
+
+  if (words.length === 0) {
+    return '';
+  }
+
+  const [firstWord, ...restWords] = words;
+
+  return firstWord.toLowerCase() + restWords.map(capitalize).join('');
+}
+
+export function dasherize(value) {
+  return splitIntoWords(value)
+    .map((word) => word.toLowerCase())
+    .join('-');
+}
