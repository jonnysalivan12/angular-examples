-      // gdzie "auth" stoi w miejscu <type>) — drift, którego plural/format check nie
-      // wykrywa, bo "auth" to poprawny singular i alias pasuje do gramatyki.
-      violations.push({
-        kind:          'alias-type-unknown',
-        alias,
-        target,
-        type_segment:  type,
-        allowed_types: ALLOWED_TYPES,
-        note:          `Segment <type> aliasu to "${type}" — nie jest dozwolonym typem [${ALLOWED_TYPES.join(', ')}]. ` +
-                       `Prawdopodobnie odwrócona kolejność <type>/<kontekst> zamiast wymaganego <kontekst>/<type>[/<name>] (nx.md).`,
