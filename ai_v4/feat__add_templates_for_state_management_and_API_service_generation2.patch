+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import os from 'node:os';
+import path from 'node:path';
+
+import { runInitState } from './init-state.js';
+
+/** Świeży katalog per test — writeNewFile odmawia nadpisania istniejących plików. */
+function makeTempDir(t) {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'init-state-'));
+  t.after(() => fs.rmSync(dir, { recursive: true, force: true }));
+  return dir;
+}
+
+test("domyślnie pliki slice'a trafiają bezpośrednio do <path>, bez podkatalogu <nazwa>/", async (t) => {
+  const target = makeTempDir(t);
+
+  await runInitState({ options: { name: 'session', path: target }, positionals: [] });
+
+  assert.ok(fs.existsSync(path.join(target, 'session-state.ts')));
+  assert.ok(fs.existsSync(path.join(target, 'api', 'session-api.service.ts')));
+  assert.ok(!fs.existsSync(path.join(target, 'session')), 'podkatalog z nazwą stanu nie może powstać');
+});
+
+test("--nested tworzy podkatalog <path>/<nazwa>/ z plikami slice'a", async (t) => {
+  const target = makeTempDir(t);
+
+  await runInitState({ options: { name: 'session', path: target, nested: true }, positionals: [] });
+
+  assert.ok(fs.existsSync(path.join(target, 'session', 'session-state.ts')));
+  assert.ok(fs.existsSync(path.join(target, 'session', 'api', 'session-api.service.ts')));
+});
+
+test('--nested nie zmienia zestawu generowanych plików, tylko ich położenie', async (t) => {
+  const flatTarget = makeTempDir(t);
+  const nestedTarget = makeTempDir(t);
+
+  await runInitState({ options: { name: 'session', path: flatTarget }, positionals: [] });
+  await runInitState({ options: { name: 'session', path: nestedTarget, nested: true }, positionals: [] });
+
+  const listFilesRelative = (rootPath) => {
+    const collected = [];
+    const walk = (dirPath) => {
+      for (const entry of fs.readdirSync(dirPath, { withFileTypes: true })) {
+        const entryPath = path.join(dirPath, entry.name);
+        if (entry.isDirectory()) walk(entryPath);
+        else collected.push(path.relative(rootPath, entryPath));
+      }
+    };
+    walk(rootPath);
+    return collected.sort();
+  };
+
+  const flatFiles = listFilesRelative(flatTarget);
+  const nestedFiles = listFilesRelative(path.join(nestedTarget, 'session'));
+  assert.deepEqual(nestedFiles, flatFiles);
+});
