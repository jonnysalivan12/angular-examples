+#!/usr/bin/env node
+import path from 'path';
+
+import { parseCommandLine, printHelp } from './utils/arg-parser.js';
+import { runInitState } from './commands/init-state.js';
+import { runAddStateAction } from './commands/add-state-action.js';
+import { runAddAsyncStateAction } from './commands/add-async-state-action.js';
+import { runAddApi } from './commands/add-api.js';
+import { fileURLToPath } from 'url';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = path.dirname(__filename);
+
+async function main() {
+  const parsed = parseCommandLine(process.argv.slice(2));
+
+  if (!parsed.command || parsed.options.help) {
+    printHelp();
+    return;
+  }
+
+  const repoRoot = path.resolve(__dirname, '..', '..');
+
+  try {
+    if (parsed.command === 'init-state') {
+      await runInitState({
+        repoRoot,
+        options: parsed.options,
+        positionals: parsed.positionals,
+      });
+      return;
+    }
+
+    if (parsed.command === 'add-state-action') {
+      await runAddStateAction({
+        repoRoot,
+        options: parsed.options,
+        positionals: parsed.positionals,
+      });
+      return;
+    }
+
+    if (parsed.command === 'add-async-state-action') {
+      await runAddAsyncStateAction({
+        repoRoot,
+        options: parsed.options,
+        positionals: parsed.positionals,
+      });
+      return;
+    }
+
+    if (parsed.command === 'add-api') {
+      await runAddApi({
+        repoRoot,
+        options: parsed.options,
+        positionals: parsed.positionals,
+      });
+      return;
+    }
+
+    throw new Error('Unknown command: ' + parsed.command);
+  } catch (error) {
+    const message = error instanceof Error ? error.message : String(error);
+    console.error('[generator-cli] ' + message);
+    process.exitCode = 1;
+  }
+}
+
+main();
