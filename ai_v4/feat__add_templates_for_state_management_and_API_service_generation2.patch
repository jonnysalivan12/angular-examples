+import fs from 'fs';
+import { template } from 'lodash-es';
+
+import { camelize, classify, dasherize } from './strings.js';
+
+function getTransform(transformName) {
+  if (transformName === 'classify') {
+    return classify;
+  }
+
+  if (transformName === 'camelize') {
+    return camelize;
+  }
+
+  if (transformName === 'dasherize') {
+    return dasherize;
+  }
+
+  return (value) => String(value);
+}
+
+export function resolveTemplateSegment(segment, context) {
+  return segment
+    .replace(/__([a-zA-Z0-9_]+)@([a-zA-Z0-9_]+)__/g, (_match, key, transformName) => {
+      const transform = getTransform(transformName);
+      const rawValue = context[key];
+
+      if (rawValue === undefined || rawValue === null) {
+        throw new Error('Template segment requires missing context key: ' + key);
+      }
+
+      return transform(rawValue);
+    })
+    .replace(/\.template$/, '');
+}
+
+function renderTemplateContent(rawTemplateContent, context) {
+  const compiledTemplate = template(rawTemplateContent, {
+    evaluate: /<%([\s\S]+?)%>/g,
+    interpolate: /<%=([\s\S]+?)%>/g,
+  });
+
+  return compiledTemplate(context);
+}
+
+export function renderTemplateFile(templateFilePath, context) {
+  const rawTemplateContent = fs.readFileSync(templateFilePath, 'utf8');
+  return renderTemplateContent(rawTemplateContent, context);
+}
