+import { toAbsolutePath } from '../utils/fs-utils.js';
+import { classify } from '../utils/strings.js';
+import {
+  updateActionFile,
+  updateStateFileForAsyncAction,
+  updateEffectFileForAsyncAction,
+} from '../utils/state-file-utils.js';
+
+function toBoolean(value, defaultValue) {
+  if (value === undefined) {
+    return defaultValue;
+  }
+
+  if (typeof value === 'boolean') {
+    return value;
+  }
+
+  const normalized = String(value).trim().toLowerCase();
+  if (normalized === 'true' || normalized === '1') {
+    return true;
+  }
+
+  if (normalized === 'false' || normalized === '0') {
+    return false;
+  }
+
+  return defaultValue;
+}
+
+export async function runAddAsyncStateAction({ repoRoot, options, positionals }) {
+  const rawName = options.name || positionals[0];
+
+  if (!rawName || typeof rawName !== 'string') {
+    throw new Error('add-async-state-action requires --name <actionName>.');
+  }
+
+  const stateFolderPath = toAbsolutePath(process.cwd(), options.path || process.cwd());
+  const requestWithPayload = toBoolean(options.requestWithPayload !== undefined ? options.requestWithPayload : positionals[1], false);
+  const successWithPayload = toBoolean(options.successWithPayload !== undefined ? options.successWithPayload : positionals[2], false);
+  const failureWithPayload = toBoolean(options.failureWithPayload !== undefined ? options.failureWithPayload : positionals[3], false);
+
+  const requestActionResult = await updateActionFile({
+    repoRoot,
+    stateFolderPath,
+    actionName: rawName + '.request',
+    withPayload: requestWithPayload,
+  });
+
+  const successActionResult = await updateActionFile({
+    repoRoot,
+    stateFolderPath,
+    actionName: rawName + '.success',
+    withPayload: successWithPayload,
+  });
+
+  const failureActionResult = await updateActionFile({
+    repoRoot,
+    stateFolderPath,
+    actionName: rawName + '.failure',
+    withPayload: failureWithPayload,
+  });
+
+  const actionFullName = [requestActionResult.rootNamespaceName]
+    .concat(rawName.split('.'))
+    .map((segment) => classify(segment))
+    .join('.');
+
+  await updateStateFileForAsyncAction({
+    repoRoot,
+    stateFolderPath,
+    requestWithPayload,
+    successWithPayload,
+    failureWithPayload,
+    actionFullName,
+    actionNodeNames: rawName.split('.'),
+    requestActionPayloadModelName: requestActionResult.actionPayloadModelName,
+    successActionPayloadModelName: successActionResult.actionPayloadModelName,
+    failureActionPayloadModelName: failureActionResult.actionPayloadModelName,
+  });
+
+  await updateEffectFileForAsyncAction({
+    repoRoot,
+    stateFolderPath,
+    requestWithPayload,
+    successWithPayload,
+    failureWithPayload,
+    actionFullName,
+    actionNodeNames: rawName.split('.'),
+  });
+
+  console.log('[generator-cli] add-async-state-action completed: ' + rawName);
+  console.log('[generator-cli] state path: ' + stateFolderPath);
+}
