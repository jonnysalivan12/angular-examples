+import { existsSync, readFileSync, readdirSync } from 'fs';
+import path from 'path';
+
+import { LIBRARY_NAMING } from './naming-config.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Library naming — deterministyczna derywacja kanonicznej nazwy projektu nx,
+ * katalogu i aliasu importu z pól strukturalnych (scope, tag/type,
+ * domain = kontekst, segment? = opcjonalna nazwa). Wzorzec (nx.md):
+ * `<basePath>/<kontekst>/<typ>[/<nazwa>]` — kontekst ZAWSZE przed typem;
+ * brak segmentu nazwy = biblioteka-barrel typu w kontekście.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+/**
+ * Domyślna konfiguracja nazewnictwa = JEDEN SSOT: `./naming-config.js`
+ * (`LIBRARY_NAMING`). NIE powielamy literałów — pola (sharedScope/sharedPrefix/
+ * appsBase/sharedBase/appProjectsBase) opisane przy źródle. Override przez 2. argument
+ * funkcji; spread `{ ...DEFAULT_NAMING, ...naming }` tworzy nowy obiekt, więc współdzielony
+ * SSOT nigdy nie jest mutowany.
+ */
+const DEFAULT_NAMING = LIBRARY_NAMING;
+
+/** Cache odczytów apps/<scope>/project.json prefix (per root|scope) — unika I/O w pętli. */
+const _prefixCache = new Map();
+
+/**
+ * Rozwiązuje prefiks (alias===selektor) dla danego scope, czytając workspace:
+ *   - scope === sharedScope → sharedPrefix (wspólny dla reużywalnych),
+ *   - inaczej → `apps/<scope>/project.json`.prefix (deklaracja przy apce),
+ *   - brak/nieczytelny project.json → fallback sharedPrefix (degradacja, nie crash).
+ *
+ * Override przez `naming.prefixByScope[scope]` (np. w testach / przy bootstrapie
+ * apki jeszcze nie istniejącej na dysku) — wtedy I/O pomijane.
+ *
+ * @param {string} scope
+ * @param {object} [naming] — override DEFAULT_NAMING (+ opc. prefixByScope, root)
+ * @returns {string|null} token prefiksu (bez `@`/`-`) lub null gdy brak scope
+ */
+export function resolveScopePrefix(scope, naming = {}) {
+  const cfg = { ...DEFAULT_NAMING, ...naming };
+  const s = clean(scope);
+  if (!s) return null;
+  if (s === cfg.sharedScope) return cfg.sharedPrefix;
+  if (cfg.prefixByScope && cfg.prefixByScope[s] != null) return cfg.prefixByScope[s];
+
+  const root = cfg.root || '.';
+  const key = `${root}␀${s}`;
+  if (_prefixCache.has(key)) return _prefixCache.get(key);
+
+  let prefix = cfg.sharedPrefix; // fallback — gdy apka nie zadeklarowała prefiksu
+  const pjPath = path.resolve(root, cfg.appProjectsBase, s, 'project.json');
+  if (existsSync(pjPath)) {
+    try {
+      const pj = JSON.parse(readFileSync(pjPath, 'utf-8'));
+      if (typeof pj?.prefix === 'string' && pj.prefix.trim()) prefix = pj.prefix.trim();
+    } catch { /* nieczytelny project.json → fallback */
+    }
+  }
+  _prefixCache.set(key, prefix);
+  return prefix;
+}
+
+/**
+ * Czy scope istnieje w workspace: scope współdzielony (sharedScope) albo aplikacja
+ * zadeklarowana w `apps/<scope>/project.json` (ta sama konwencja co resolveScopePrefix).
+ * Używane do walidacji `scope:` z target.yaml feature'a (utils.loadFeatureScope).
+ *
+ * @param {string} scope
+ * @param {object} [naming] — override DEFAULT_NAMING (+ opc. root)
+ * @returns {boolean}
+ */
+export function isKnownScope(scope, naming = {}) {
+  const cfg = { ...DEFAULT_NAMING, ...naming };
+  const s = clean(scope);
+  if (!s) return false;
+  if (s === cfg.sharedScope) return true;
+  const root = cfg.root || '.';
+  return existsSync(path.resolve(root, cfg.appProjectsBase, s, 'project.json'));
+}
+
+/**
+ * Lista dostępnych scope'ów story: sharedScope + aplikacje z workspace (katalogi
+ * w appProjectsBase zawierające project.json). Do komunikatów błędów i toolingu.
+ *
+ * @param {object} [naming] — override DEFAULT_NAMING (+ opc. root)
+ * @returns {string[]} — sharedScope pierwszy, potem aplikacje alfabetycznie
+ */
+export function listAppScopes(naming = {}) {
+  const cfg = { ...DEFAULT_NAMING, ...naming };
+  const root = cfg.root || '.';
+  const appsRoot = path.resolve(root, cfg.appProjectsBase);
+  let apps = [];
+  if (existsSync(appsRoot)) {
+    apps = readdirSync(appsRoot, { withFileTypes: true })
+      .filter((e) => e.isDirectory() && existsSync(path.join(appsRoot, e.name, 'project.json')))
+      .map((e) => e.name)
+      .sort();
+  }
+  return [cfg.sharedScope, ...apps];
+}
+
+/**
+ * Derywuje kanoniczną nazwę/katalog/alias/selektor z pól strukturalnych biblioteki.
+ *
+ * Pole `domain` niesie KONTEKST (obszar jednej domeny biznesowej; kod przekrojowy
+ * = `common`) i staje się segmentem PRZED typem. Pole `segment` (opcjonalne)
+ * to nazwa biblioteki po typie — bez niego biblioteka jest barrelem typu
+ * w kontekście (dla asset/model/util to jedyna dozwolona forma).
+ *
+ * @param {{scope?: string, tag?: string, domain?: string, segment?: string}} lib
+ * @param {object} [naming] — override DEFAULT_NAMING (sharedScope/sharedPrefix/
+ *   appsBase/sharedBase/appProjectsBase + opc. prefixByScope, root)
+ * @returns {{name: string, directory: string, importPath: string, selectorPrefix: string} | null}
+ *          null gdy brak `scope` lub `tag` (np. wpis libraries.modified wskazujący
+ *          istniejący projekt-aplikację — wtedy konwencja libów nie ma zastosowania).
+ */
+export function deriveLibraryNaming(lib, naming = {}) {
+  const cfg = { ...DEFAULT_NAMING, ...naming };
+  const scope = clean(lib?.scope);
+  const type = clean(lib?.tag);
+  const context = clean(lib?.domain);
+  const segment = clean(lib?.segment);
+
+  if (!scope || !type) return null; // brak danych strukturalnych → nie derywujemy
+
+  const isShared = scope === cfg.sharedScope;
+  const prefix = resolveScopePrefix(scope, cfg);
+
+  // Segmenty po <basePath>: `<kontekst>/<typ>[/<nazwa>]`; bez kontekstu (dane
+  // niepełne) degradacja do samego `<typ>[/<nazwa>]`.
+  const segs = [...(context ? [context] : []), type, ...(segment ? [segment] : [])];
+  const baseDir = isShared ? cfg.sharedBase : `${cfg.appsBase}/${scope}`;
+
+  // Alias: reużywalne TRZYMAJĄ segment scope (@<prefix>/<scope>/<segs>); app-owe
+  // SKŁADAJĄ apkę w prefiks, więc scope NIE powtarza się w ścieżce (@<prefix>/<segs>).
+  const aliasBody = isShared ? `${scope}/${segs.join('/')}` : segs.join('/');
+
+  return {
+    name: [scope, ...segs].join('-'),
+    directory: [baseDir, ...segs].join('/'),
+    importPath: `@${prefix}/${aliasBody}`,
+    selectorPrefix: prefix
+  };
+}
+
+/**
+ * Porównuje wartości obserwowane (z LLM) z kanonicznymi i zwraca listę odchyleń.
+ * Używane przez gate widoczności (planner aggregator) — drift jest LOGOWANY,
+ * a nie tylko cicho korygowany.
+ *
+ * @param {{name?: string, path?: string, importPath?: string}} observed
+ * @param {{name: string, directory: string, importPath: string}} canonical
+ * @returns {Array<{field: string, observed: string, canonical: string}>}
+ */
+export function diffLibraryNaming(observed, canonical) {
+  const out = [];
+  const checks = [
+    ['name', observed?.name, canonical.name],
+    ['path', observed?.path, canonical.directory],
+    ['importPath', observed?.importPath, canonical.importPath]
+  ];
+  for (const [field, obs, canon] of checks) {
+    if (obs != null && String(obs) !== String(canon)) {
+      out.push({ field, observed: String(obs), canonical: String(canon) });
+    }
+  }
+  return out;
+}
+
+function clean(v) {
+  return typeof v === 'string' ? v.trim() : '';
+}
