@@ -0,0 +1,181 @@
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+
+import {
+  librarySpec,
+  libraryCommandLine,
+  validateLibraryInput,
+  verifyGeneratedLibrary,
+  collectionFor,
+  LIBRARY_TYPES,
+  JS_LIBRARY_TYPES,
+} from './index.js';
+
+/* `naming` nadpisywane w testach (prefixByScope), żeby derywacja nie czytała
+ * project.json apki z dysku. */
+const NAMING = { prefixByScope: { 'frontend-app': 'gdprrt-app' } };
+
+test('librarySpec: biblioteka app-owa — kanon nazwy/katalogu/aliasu, scope nie powtarza się w aliasie', () => {
+  const spec = librarySpec({ scope: 'frontend-app', type: 'feature', context: 'export', name: 'wizard' }, NAMING);
+
+  assert.equal(spec.name, 'frontend-app-export-feature-wizard');
+  assert.equal(spec.directory, 'libs/apps/frontend-app/export/feature/wizard');
+  assert.equal(spec.importPath, '@gdprrt-app/export/feature/wizard');
+  assert.equal(spec.prefix, 'gdprrt-app');
+  assert.deepEqual(spec.tags, ['scope:frontend-app', 'type:feature', 'context:export']);
+  assert.equal(spec.produces, 'libs/apps/frontend-app/export/feature/wizard/project.json');
+});
+
+test('librarySpec: biblioteka reużywalna (barrel) — pełna komenda co do znaku', () => {
+  const spec = librarySpec({ scope: 'shared', type: 'util', context: 'common' }, NAMING);
+
+  assert.equal(
+    libraryCommandLine(spec),
+    'npx nx g @nx/angular:library --name=shared-common-util --directory=libs/shared/common/util '
+    + '--importPath=@gdprrt/shared/common/util --prefix=gdprrt --tags=scope:shared,type:util,context:common '
+    + '--standalone=false --skipModule --no-interactive',
+  );
+});
+
+test('librarySpec: brak scope/type → null (nie ma z czego wyderywować kanonu)', () => {
+  assert.equal(librarySpec({ context: 'auth' }, NAMING), null);
+  assert.equal(librarySpec({ scope: 'shared', context: 'auth' }, NAMING), null);
+  assert.equal(librarySpec({ type: 'ui', context: 'auth' }, NAMING), null);
+});
+
+test('validateLibraryInput: poprawne wejścia przechodzą (z nazwą i barrel)', () => {
+  assert.deepEqual(validateLibraryInput({ scope: 'shared', type: 'ui', context: 'common', name: 'button' }), []);
+  assert.deepEqual(validateLibraryInput({ scope: 'shared', type: 'util', context: 'common' }), []);
+});
+
+test('validateLibraryInput: braki i zły typ zgłaszane osobno', () => {
+  const errors = validateLibraryInput({ type: 'nonsens' });
+  assert.equal(errors.length, 3);
+  assert.match(errors[0], /--scope/);
+  assert.match(errors[1], /nieznany --type 'nonsens'/);
+  assert.match(errors[2], /--context/);
+});
+
+test('validateLibraryInput: --name zabronione dla typów barrelowych', () => {
+  for (const type of ['asset', 'model', 'util']) {
+    const errors = validateLibraryInput({ scope: 'shared', type, context: 'common', name: 'x' });
+    assert.equal(errors.length, 1, type);
+    assert.match(errors[0], /--name niedozwolone/);
+  }
+});
+
+test('LIBRARY_TYPES: pełna oś type: konfiguracji granic', () => {
+  assert.deepEqual(LIBRARY_TYPES, ['feature', 'ui', 'state', 'core', 'model', 'util', 'asset']);
+});
+
+/* ── Kolekcja wyprowadzona z typu ──────────────────────────────────────────── */
+
+test('collectionFor: asset bez Angulara, pozostałe typy z Angularem', () => {
+  assert.deepEqual(JS_LIBRARY_TYPES, ['asset']);
+  assert.equal(collectionFor('asset'), '@nx/js:library');
+  for (const type of LIBRARY_TYPES.filter((t) => t !== 'asset')) {
+    assert.equal(collectionFor(type), '@nx/angular:library', type);
+  }
+});
+
+test('librarySpec: asset → kolekcja JS bez flag Angulara, kanon nazw bez zmian', () => {
+  const spec = librarySpec({ scope: 'shared', type: 'asset', context: 'common' }, NAMING);
+
+  assert.equal(spec.collection, '@nx/js:library');
+  assert.equal(spec.name, 'shared-common-asset');
+  assert.equal(spec.directory, 'libs/shared/common/asset');
+  assert.equal(spec.importPath, '@gdprrt/shared/common/asset');
+  assert.deepEqual(spec.tags, ['scope:shared', 'type:asset', 'context:common']);
+  assert.equal(
+    libraryCommandLine(spec),
+    'npx nx g @nx/js:library --name=shared-common-asset --directory=libs/shared/common/asset '
+    + '--importPath=@gdprrt/shared/common/asset --tags=scope:shared,type:asset,context:common --no-interactive',
+  );
+});
+
+test('librarySpec: kolekcja JS nie dostaje parametrów, których nie zna', () => {
+  const spec = librarySpec({ scope: 'shared', type: 'asset', context: 'common' }, NAMING);
+
+  for (const flag of ['--prefix', '--standalone', '--skipModule']) {
+    assert.ok(!spec.args.some((argument) => argument.startsWith(flag)), `${flag} nie istnieje w @nx/js:library`);
+  }
+});
+
+test('librarySpec: buildowalności NIE wymuszamy flagą — domyślne obu kolekcji stoją w nx.json', () => {
+  const asset = librarySpec({ scope: 'shared', type: 'asset', context: 'common' }, NAMING);
+  const ui = librarySpec({ scope: 'shared', type: 'ui', context: 'common', name: 'button' }, NAMING);
+
+  for (const spec of [asset, ui]) {
+    assert.ok(
+      !spec.args.some((argument) => /--bundler|--buildable|--publishable/.test(argument)),
+      `${spec.collection}: domyślne parametry generatora należą do nx.json`,
+    );
+  }
+});
+
+/* ── Bramka „żadna biblioteka nie jest buildable" ──────────────────────────── */
+
+const BUILDABLE_SPEC = librarySpec({ scope: 'shared', type: 'util', context: 'common' }, NAMING);
+
+/** Kształt przepisany z realnej generacji: biblioteka nie-buildable ma sam lint. */
+const GENERATED = {
+  'libs/shared/common/util/project.json': {
+    name: 'shared-common-util',
+    prefix: 'gdprrt',
+    projectType: 'library',
+    tags: ['scope:shared', 'type:util', 'context:common'],
+    targets: { lint: { executor: '@nx/eslint:lint' } },
+  },
+  'tsconfig.base.json': {
+    compilerOptions: { paths: { '@gdprrt/shared/common/util': ['./libs/shared/common/util/src/index.ts'] } },
+  },
+};
+
+const readFrom = (files) => (path) => files[path] ?? null;
+
+test('verifyGeneratedLibrary: biblioteka bez targetu build przechodzi', () => {
+  const verdict = verifyGeneratedLibrary(BUILDABLE_SPEC, { readJson: readFrom(GENERATED) });
+  assert.equal(verdict.ok, true, JSON.stringify(verdict.findings));
+});
+
+test('verifyGeneratedLibrary: target build → odrzucenie (biblioteka buildable)', () => {
+  const withBuild = {
+    ...GENERATED,
+    'libs/shared/common/util/project.json': {
+      ...GENERATED['libs/shared/common/util/project.json'],
+      targets: {
+        lint: { executor: '@nx/eslint:lint' },
+        build: { executor: '@nx/angular:ng-packagr-lite' },
+      },
+    },
+  };
+  const verdict = verifyGeneratedLibrary(BUILDABLE_SPEC, { readJson: readFrom(withBuild) });
+
+  assert.equal(verdict.ok, false);
+  assert.match(verdict.findings.map((finding) => finding.message).join(';'), /żadna biblioteka nie jest buildable/);
+});
+
+test('verifyGeneratedLibrary: bramka nie zależy od kolekcji — buildable z @nx/js:library też odpada', () => {
+  const jsBuildable = {
+    ...GENERATED,
+    'libs/shared/common/util/project.json': {
+      ...GENERATED['libs/shared/common/util/project.json'],
+      targets: { lint: { executor: '@nx/eslint:lint' }, build: { executor: '@nx/js:tsc' } },
+    },
+  };
+  const verdict = verifyGeneratedLibrary(BUILDABLE_SPEC, { readJson: readFrom(jsBuildable) });
+
+  assert.equal(verdict.ok, false);
+  assert.match(verdict.findings.map((finding) => finding.message).join(';'), /żadna biblioteka nie jest buildable/);
+});
+
+test('verifyGeneratedLibrary: build-storybook to inny target — nie jest mylony z buildem biblioteki', () => {
+  const withStorybook = {
+    ...GENERATED,
+    'libs/shared/common/util/project.json': {
+      ...GENERATED['libs/shared/common/util/project.json'],
+      targets: { lint: { executor: '@nx/eslint:lint' }, 'build-storybook': { executor: '@storybook/angular:build-storybook' } },
+    },
+  };
+  assert.equal(verifyGeneratedLibrary(BUILDABLE_SPEC, { readJson: readFrom(withStorybook) }).ok, true);
+});
