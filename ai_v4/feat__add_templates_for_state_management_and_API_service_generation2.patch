+import { existsSync, readFileSync } from 'fs';
+// Importy nazwane, nie domyślne: ten projekt kompiluje się bez `esModuleInterop`,
+// więc `import path from 'path'` dałoby `undefined`.
+import { basename, dirname, join } from 'path';
+
+import { ESLintUtils } from '@typescript-eslint/utils';
+
+import { checkReadme } from '../../../scripts/validators/readme-validator.js';
+
+/**
+ * Reguła: biblioteka musi mieć README z wypełnionym blokiem metadanych
+ * (name, description, status).
+ *
+ * Wisi na `project.json`, bo sprawdzenie dotyczy PROJEKTU, nie pojedynczego pliku
+ * źródłowego — dzięki temu `nx lint <biblioteka>` zgłasza brak opisu raz na projekt,
+ * tak samo jak każdy inny błąd lintu. Projekty bez `projectType: library`
+ * (aplikacje, ten projekt reguł) są pomijane.
+ *
+ * Samo sprawdzenie mieszka w `scripts/validators/readme-validator.js` i jest
+ * współdzielone z przeglądem całego repozytorium (`npm run validate:readme`),
+ * więc obie drogi zgłaszają dokładnie to samo.
+ */
+// NOTE: The rule will be available in ESLint configs as "@nx/workspace-library-readme"
+export const RULE_NAME = 'library-readme';
+
+export const rule = ESLintUtils.RuleCreator(() => __filename)({
+  name: RULE_NAME,
+  meta: {
+    type: 'problem',
+    docs: {
+      description: 'Biblioteka ma README z wypełnionym blokiem metadanych (name, description, status).',
+    },
+    schema: [],
+    messages: {
+      readmeIncomplete: 'README biblioteki: {{note}} [{{kind}}]',
+    },
+  },
+  defaultOptions: [],
+  create(context) {
+    return {
+      Program(node): void {
+        const directory = dirname(context.filename);
+
+        let projectJson: { name?: string; projectType?: string };
+        try {
+          projectJson = JSON.parse(context.sourceCode.getText());
+        } catch {
+          return; // niepoprawny JSON zgłasza parser, nie ta reguła
+        }
+        if (projectJson?.projectType !== 'library') return;
+
+        const readmePath = join(directory, 'README.md');
+        const violations = checkReadme({
+          projectName: projectJson.name ?? basename(directory),
+          directory,
+          readmeText: existsSync(readmePath) ? readFileSync(readmePath, 'utf-8') : null,
+        });
+
+        for (const violation of violations) {
+          context.report({
+            node,
+            messageId: 'readmeIncomplete',
+            data: { note: violation.note, kind: violation.kind },
+          });
+        }
+      },
+    };
+  },
+});
