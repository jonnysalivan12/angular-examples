+    await addPayloadModelFile({
+      repoRoot: options.repoRoot,
+      stateFolderPath: options.stateFolderPath,
+      payloadModelName: actionPayloadModelName,
+      payloadContent: options.payloadContent,
+      payloadImports: options.payloadImports,
+    });
+  }
+
+  await writeFormattedTypeScript(actionsFilePath, updatedActionsContent);
+
+  return {
+    rootNamespaceName,
+    actionNodeNames,
+    actionPayloadModelName,
+  };
+}
+
+export async function updateStateFile(options) {
+  const stateFileName = findFileInDir(options.stateFolderPath, '-state.ts');
+  if (!stateFileName) {
+    throw new Error('*-state.ts file not found in path: ' + options.stateFolderPath);
+  }
+
+  const stateFilePath = path.join(options.stateFolderPath, stateFileName);
+  let stateContent = normalizeLineEndings(fs.readFileSync(stateFilePath, 'utf8'));
+
+  const stateClassMatch = /export\s+class\s+([A-Za-z0-9_]+)/.exec(stateContent);
+  if (!stateClassMatch) {
+    throw new Error('Cannot find state class declaration in file: ' + stateFilePath);
+  }
+
+  const stateClassName = stateClassMatch[1];
+  const stateModelName = stateClassName + 'Model';
+  const methodName = camelize(options.actionNodeNames.join('-'));
+
+  const methodNodeContent = renderTemplateFromRepo(options.repoRoot, path.join('add-state-action', 'simple-action-patch-state-method.template'), {
+    withPayload: options.withPayload,
+    actionName: options.actionFullName,
+    methodName,
+    stateModeName: stateModelName,
+    actionPayloadName: options.actionPayloadModelName,
+    actionContent: options.actionContent,
+  });
+
+  const classCloseBraceIndex = findClassCloseBraceIndex(stateContent, stateClassName);
+  if (classCloseBraceIndex === undefined) {
+    throw new Error('Cannot resolve class end for: ' + stateClassName);
+  }
+
+  stateContent =
+    stateContent.slice(0, classCloseBraceIndex) +
+    '\n' +
+    methodNodeContent +
+    stateContent.slice(classCloseBraceIndex);
+
+  await writeFormattedTypeScript(stateFilePath, stateContent);
+}
+
+export async function updateStateFileForAsyncAction(options) {
