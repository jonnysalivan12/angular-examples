+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Konwencja nazewnictwa bibliotek — założenia SPECYFICZNE DLA TEGO REPOZYTORIUM
+ * (SSOT treściowy: docs/standards/nx.md).
+ *
+ * Z tych wartości deterministycznie derywuje się nazwa projektu nx, katalog
+ * i alias importu z trójki (scope, tag/type, domain) — patrz `library-naming.js`.
+ * Wzorzec katalogu i aliasu: `<basePath>/<kontekst>/<typ>[/<nazwa>]`.
+ *
+ * Model app-agnostyczny: monorepo może mieć wiele apek, więc prefiks aliasu/selektora
+ * NIE jest globalną stałą — to jeden identyfikator per cel (alias === selektor).
+ *
+ * Adaptacja generatorów do innego repozytorium = edycja tego pliku.
+ * Wszystkie ścieżki są liczone od korzenia repozytorium.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+export const LIBRARY_NAMING = Object.freeze({
+  /** Scope bibliotek reużywalnych; ich katalogi żyją w `sharedBase`, poza apps/<app>. */
+  sharedScope: 'shared',
+
+  /** Wspólny prefiks WSZYSTKICH bibliotek reużywalnych (alias i selektor naraz).
+   *  Prefiksy bibliotek app-owych nie stoją tutaj — deklaruje je pole `prefix`
+   *  w `apps/<scope>/project.json`, czytane z workspace przy derywacji. */
+  sharedPrefix: 'gdprrt',
+
+  /** Korzeń bibliotek przypisanych do apki. */
+  appsBase: 'libs/apps',
+
+  /** Korzeń bibliotek reużywalnych. */
+  sharedBase: 'libs/shared',
+
+  /** Korzeń projektów apek (nx `workspaceLayout.appsDir`) — stąd czytany jest prefiks apki. */
+  appProjectsBase: 'apps',
+});
