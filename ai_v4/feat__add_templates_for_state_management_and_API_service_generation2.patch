@@ -0,0 +1,348 @@
+#!/usr/bin/env node
+import { readFileSync, existsSync, readdirSync } from 'fs';
+import path from 'path';
+import { LIBRARY_NAMING } from '../generators/utils/naming-config.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Naming validator — deterministyczny CLI utility do wykrywania niespójności
+ * między tsconfig path_aliases a faktyczną strukturą katalogów libs/.
+ *
+ * Reguła (z docs/standards/nx.md):
+ *   Directory AND alias MUST: `<basePath>/<kontekst>/<type>[/<name>]` where <type>
+ *   SINGULAR (feature, state, ui, core, model, util, asset); kontekst ZAWSZE
+ *   przed typem; brak <name> = biblioteka-barrel typu w kontekście.
+ *
+ * Wykrywane violations:
+ *   1. alias-path-missing — alias wskazuje na nieistniejący katalog
+ *   2. alias-plural-type — alias zawiera plural type ("features", "states", ...)
+ *   3. directory-plural-type — katalog ma plural type w nazwie
+ *   4. directory-missing-alias — katalog libs/.../src istnieje,
+ *      ale brak zarejestrowanego aliasu w tsconfig
+ *   5. alias-format-invalid — alias nie pasuje do żadnej z dwóch gramatyk (niżej)
+ *   6. alias-type-unknown — segment <type> aliasu nie jest dozwolonym typem
+ *      (łapie odwróconą kolejność <type>/<kontekst>, np. `core/auth` zamiast `auth/core`)
+ *
+ * Dwie gramatyki aliasów (model app-agnostyczny — SSOT: nx.md, library-naming.js):
+ *   - REUŻYWALNE (prefix === sharedPrefix): `@<sharedPrefix>/<scope>/<kontekst>/<type>[/<name>]`
+ *     — scope (np. shared) jest segmentem ścieżki, po nim kontekst, po nim type.
+ *   - APP-OWE   (prefix !== sharedPrefix): `@<prefix>/<kontekst>/<type>[/<name>]`
+ *     — apka jest W prefiksie, więc scope NIE powtarza się; kontekst PIERWSZY, type po nim.
+ * Dyskryminator = czy prefiks aliasu równa się sharedPrefix. Segment na pozycji
+ * <type> musi być typem — to wykrywa odwróconą kolejność w OBU gramatykach.
+ *
+ * Output:
+ *   - human: tabela violations na stdout (default)
+ *   - json: structured JSON
+ *   - yaml: structured YAML (do embedu w system-constraints.yaml)
+ *
+ * Exit code: 0 jeśli zero violations, 1 jeśli są (do CI).
+ *
+ * Użycie:
+ *   node scripts/validators/naming-validator.js [--format=human|json|yaml] [--root=.]
+ *     [--shared-prefix=<prefix>]
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const ALLOWED_TYPES = ['feature', 'state', 'ui', 'core', 'model', 'util', 'asset'];
+const PLURAL_OF = {
+  features: 'feature',
+  states:   'state',
+  uis:      'ui',
+  cores:    'core',
+  models:   'model',
+  utils:    'util',
+  assets:   'asset',
+};
+
+function main() {
+  const args = parseArgs(process.argv.slice(2));
+  const root = path.resolve(args.root || '.');
+  const format = args.format || 'human';
+  // Prefiks reużywalnych libów z JEDYNEGO SSOT (naming-config LIBRARY_NAMING) — to on
+  // rozstrzyga gramatykę aliasu. CLI nadpisuje per-workspace; NIE hardcoduj prefiksu.
+  const sharedPrefix = args['shared-prefix'] || LIBRARY_NAMING.sharedPrefix;
+
+  const tsconfigPath = path.join(root, 'tsconfig.base.json');
+  if (!existsSync(tsconfigPath)) {
+    fail(`Brak tsconfig.base.json w ${root}.`);
+  }
+
+  const libsRoot = path.join(root, 'libs');
+  if (!existsSync(libsRoot)) {
+    fail(`Brak libs/ w ${root}.`);
+  }
+
+  const tsconfig = parseJsonStripComments(readFileSync(tsconfigPath, 'utf-8'));
+  const pathAliases = tsconfig?.compilerOptions?.paths || {};
+
+  // Indeks: faktyczne libs na dysku (path → boolean exists)
+  const directoriesOnDisk = walkLibs(libsRoot);
+
+  // Indeks: aliasy z tsconfig
+  const aliases = Object.entries(pathAliases).map(([alias, paths]) => ({
+    alias,
+    target: Array.isArray(paths) ? paths[0] : paths,
+  }));
+
+  const violations = [];
+
+  // ── 1. alias-path-missing + 2. alias-plural-type + 5/6. format/type ──
+  for (const { alias, target } of aliases) {
+    const parsed = parseAlias(alias, sharedPrefix);
+    if (!parsed) {
+      violations.push({
+        kind:   'alias-format-invalid',
+        alias,
+        target,
+        note:   `Alias nie pasuje do żadnej gramatyki: reużywalne @${sharedPrefix}/<scope>/<kontekst>/<type>[/<name>] ani app-owe @<prefix>/<kontekst>/<type>[/<name>].`,
+      });
+      continue;
+    }
+    const { type } = parsed;
+
+    // 2. plural-type w aliasie
+    if (PLURAL_OF[type] && PLURAL_OF[type] !== type) {
+      violations.push({
+        kind:        'alias-plural-type',
+        alias,
+        target,
+        plural_used: type,
+        should_be:   PLURAL_OF[type],
+        note:        `Alias używa plural "${type}", powinno być singular "${PLURAL_OF[type]}".`,
+      });
+    } else if (!ALLOWED_TYPES.includes(type)) {
+      // 6. type-unknown — segment na pozycji <type> nie jest dozwolonym typem.
+      // Łapie ODWRÓCONĄ KOLEJNOŚĆ `<domain>/<type>` (np. app-owy @<app-prefix>/auth/core,
+      // gdzie "auth" stoi w miejscu <type>) — drift, którego plural/format check nie
+      // wykrywa, bo "auth" to poprawny singular i alias pasuje do gramatyki.
+      violations.push({
+        kind:          'alias-type-unknown',
+        alias,
+        target,
+        type_segment:  type,
+        allowed_types: ALLOWED_TYPES,
+        note:          `Segment <type> aliasu to "${type}" — nie jest dozwolonym typem [${ALLOWED_TYPES.join(', ')}]. ` +
+                       `Prawdopodobnie odwrócona kolejność <type>/<kontekst> zamiast wymaganego <kontekst>/<type>[/<name>] (nx.md).`,
+      });
+    }
+
+    // 1. path-missing — target wskazuje na non-existent file/dir
+    const targetAbs = path.resolve(root, target.replace(/^\.\//, ''));
+    const targetDir = targetAbs.endsWith('.ts') ? path.dirname(targetAbs) : targetAbs;
+    if (!existsSync(targetDir)) {
+      violations.push({
+        kind:   'alias-path-missing',
+        alias,
+        target,
+        note:   `Alias wskazuje na nieistniejący katalog: ${path.relative(root, targetDir)}`,
+      });
+    }
+  }
+
+  // ── 3. directory-plural-type — dowolny segment ścieżki w liczbie mnogiej ──
+  // Układy z kontekstem: shared/<kontekst>/<type>[/<name>], apps/<app>/<kontekst>/<type>[/<name>]
+  // — typ może być ostatnim segmentem (barrel) albo przedostatnim (nazwa po typie),
+  // więc plural sprawdzamy w KAŻDYM segmencie ścieżki biblioteki.
+  for (const dir of directoriesOnDisk) {
+    const rel = path.relative(libsRoot, dir).split(path.sep);
+    for (const seg of rel) {
+      if (PLURAL_OF[seg] && PLURAL_OF[seg] !== seg) {
+        violations.push({
+          kind:        'directory-plural-type',
+          directory:   path.relative(root, dir),
+          plural_used: seg,
+          should_be:   PLURAL_OF[seg],
+          note:        `Katalog używa plural "${seg}/", powinno być singular "${PLURAL_OF[seg]}/".`,
+        });
+      }
+    }
+  }
+
+  // ── 4. directory-missing-alias — katalog istnieje, brak aliasu w tsconfig ──
+  const aliasTargets = new Set(
+    aliases.map(a => {
+      const tgt = path.resolve(root, a.target.replace(/^\.\//, ''));
+      return tgt.endsWith('.ts') ? path.dirname(tgt) : tgt;
+    })
+  );
+  // src/ subdir aliasów też brane pod uwagę — sprawdzamy lib root
+  const aliasLibRoots = new Set(
+    [...aliasTargets].map(tgt => {
+      // alias zwykle wskazuje na .../src/index.ts → lib root to .../
+      const idx = tgt.lastIndexOf(`${path.sep}src`);
+      return idx > 0 ? tgt.slice(0, idx) : tgt;
+    })
+  );
+  for (const dir of directoriesOnDisk) {
+    if (!aliasLibRoots.has(dir)) {
+      violations.push({
+        kind:      'directory-missing-alias',
+        directory: path.relative(root, dir),
+        note:      'Katalog biblioteki istnieje (libs/.../<type>/<name>/src), ale brak aliasu w tsconfig.base.json.',
+      });
+    }
+  }
+
+  // ── Output ────────────────────────────────────────────────────────────────
+  const summary = {
+    root,
+    aliases_checked:        aliases.length,
+    directories_checked:    directoriesOnDisk.length,
+    violations_count:       violations.length,
+    violations,
+    generated_at:           new Date().toISOString(),
+  };
+
+  switch (format) {
+    case 'json':
+      process.stdout.write(JSON.stringify(summary, null, 2) + '\n');
+      break;
+    case 'yaml':
+      process.stdout.write(toYaml(summary));
+      break;
+    case 'human':
+    default:
+      printHuman(summary);
+  }
+
+  process.exit(violations.length > 0 ? 1 : 0);
+}
+
+// ── Helpers ────────────────────────────────────────────────────────────────
+
+/**
+ * Walk libs/ w poszukiwaniu katalogów bibliotek. Library = katalog zawierający `src/`.
+ */
+function walkLibs(libsRoot) {
+  const results = [];
+  function walk(dir) {
+    let entries;
+    try {
+      entries = readdirSync(dir, { withFileTypes: true });
+    } catch {
+      return;
+    }
+    // Jeśli ten katalog zawiera src/ — to jest library root
+    const hasSrc = entries.some(e => e.isDirectory() && e.name === 'src');
+    if (hasSrc) {
+      results.push(dir);
+      // NIE walkuj dalej — nested libs to anti-pattern
+      return;
+    }
+    for (const e of entries) {
+      if (!e.isDirectory()) continue;
+      if (e.name === 'node_modules' || e.name.startsWith('.')) continue;
+      walk(path.join(dir, e.name));
+    }
+  }
+  walk(libsRoot);
+  return results;
+}
+
+/**
+ * Parsuje alias do {prefix, scope, context, type, name} wg jednej z dwóch gramatyk.
+ * Dyskryminator: prefix === sharedPrefix → reużywalna (scope jest segmentem),
+ * inaczej → app-owa (apka w prefiksie, brak segmentu scope; kontekst pierwszy).
+ *
+ *   reużywalna: @<sharedPrefix>/<scope>/<kontekst>/<type>[/<name>]  (3–4 segmenty po prefiksie)
+ *   app-owa:    @<prefix>/<kontekst>/<type>[/<name>]                 (2–3 segmenty po prefiksie)
+ *
+ * @returns {{prefix:string, scope:string|null, context:string, type:string, name:string|null}|null}
+ *          null gdy alias nie pasuje do żadnej gramatyki (→ alias-format-invalid).
+ */
+function parseAlias(alias, sharedPrefix) {
+  const m = alias.match(/^@([^/]+)\/(.+)$/);
+  if (!m) return null;
+  const prefix = m[1];
+  const tail = m[2].split('/').filter(Boolean);
+  if (tail.length === 0) return null;
+
+  if (prefix === sharedPrefix) {
+    // reużywalna: <scope>/<kontekst>/<type>[/<name>] — wymaga ≥3 segmentów
+    if (tail.length < 3 || tail.length > 4) return null;
+    return { prefix, scope: tail[0], context: tail[1], type: tail[2], name: tail[3] ?? null };
+  }
+  // app-owa: <kontekst>/<type>[/<name>] — apka jest w prefiksie
+  if (tail.length < 2 || tail.length > 3) return null;
+  return { prefix, scope: null, context: tail[0], type: tail[1], name: tail[2] ?? null };
+}
+
+function parseJsonStripComments(text) {
+  // Minimalne stripping komentarzy // i /* */ dla tsconfig.json
+  const stripped = text
+    .replace(/\/\*[\s\S]*?\*\//g, '')
+    .replace(/\/\/.*$/gm, '');
+  return JSON.parse(stripped);
+}
+
+function parseArgs(argv) {
+  const args = {};
+  for (const a of argv) {
+    const m = a.match(/^--([^=]+)(?:=(.*))?$/);
+    if (m) args[m[1]] = m[2] || true;
+  }
+  return args;
+}
+
+function fail(msg) {
+  process.stderr.write(`naming-validator: ${msg}\n`);
+  process.exit(2);
+}
+
+function printHuman({ aliases_checked, directories_checked, violations_count, violations }) {
+  console.log(`naming-validator — checked ${aliases_checked} aliases, ${directories_checked} library directories`);
+  if (violations_count === 0) {
+    console.log('✓ No violations found.');
+    return;
+  }
+  console.log(`✗ ${violations_count} violation(s):\n`);
+  for (const v of violations) {
+    const head = `[${v.kind}]`;
+    const subject = v.alias || v.directory || '?';
+    console.log(`  ${head} ${subject}`);
+    if (v.note) console.log(`    ${v.note}`);
+    if (v.target) console.log(`    → target: ${v.target}`);
+    if (v.should_be) console.log(`    → should be: ${v.should_be}`);
+    console.log();
+  }
+}
+
+function toYaml(obj) {
+  // Minimalny YAML serializer — wystarczy dla naming-violations w system-constraints.yaml
+  // Nie używamy `yaml` package żeby utility był standalone (zero deps poza fs+path).
+  const escape = (s) => {
+    const str = String(s);
+    if (/[:#\n"\\]/.test(str) || str.startsWith('@') || str.startsWith('-')) {
+      return JSON.stringify(str);
+    }
+    return str;
+  };
+  function serialize(value, depth = 0) {
+    const pad = ' '.repeat(depth);
+    if (value === null || value === undefined) return 'null';
+    if (typeof value === 'number' || typeof value === 'boolean') return String(value);
+    if (typeof value === 'string') return escape(value);
+    if (Array.isArray(value)) {
+      if (value.length === 0) return '[]';
+      return '\n' + value.map(item => {
+        const s = serialize(item, depth + 2);
+        return s.startsWith('\n')
+          ? `${pad}-${s}`
+          : `${pad}- ${s}`;
+      }).join('\n');
+    }
+    if (typeof value === 'object') {
+      const keys = Object.keys(value);
+      if (keys.length === 0) return '{}';
+      return '\n' + keys.map(k => {
+        const s = serialize(value[k], depth + 2);
+        return s.startsWith('\n')
+          ? `${pad}${k}:${s}`
+          : `${pad}${k}: ${s}`;
+      }).join('\n');
+    }
+    return String(value);
+  }
+  return 'naming_validation:' + serialize(obj, 2) + '\n';
+}
+
+main();
