From 98ec5b9401ed535dc9e87c66d0f54ca9d3e9fbee Mon Sep 17 00:00:00 2001
From: Igor Stadnik <stadnikigorua@gmail.com>
Date: Tue, 16 Jun 2026 23:02:00 +0200
Subject: [PATCH 1/3] Refactor story readiness YAML: enhance clarity of data
 states and interactions, improve questions for better compliance with
 standards

---
 .../checklists/story-readiness.yaml           | 48 ++++++++++---------
 1 file changed, 26 insertions(+), 22 deletions(-)

diff --git a/.github/agents/story-flow/story-clarifier/checklists/story-readiness.yaml b/.github/agents/story-flow/story-clarifier/checklists/story-readiness.yaml
index 1fa5353..3b165d2 100644
--- a/.github/agents/story-flow/story-clarifier/checklists/story-readiness.yaml
+++ b/.github/agents/story-flow/story-clarifier/checklists/story-readiness.yaml
@@ -117,13 +117,21 @@ categories:
         source: functional
         section: happy
       - id: data.states
-        # Stany danych domyślnie pochodzą z makiety (zawiera wszystkie stany, design-handoff.md §6) + wzorców design-system.md. Pytaj tylko o świadomie pominięte/nietypowe.
-        # MECHANIKA stanu loading (co jest disabled/zablokowane podczas requestu) jest STANDARDEM:
-        # w `pending` blokowany jest cały formularz — pola + CTA (forms.md §4). NIE pytaj, czy „zablokowany
-        # formularz" to sam przycisk, czy też pola — domyślnie oba.
-        q: Nietypowe lub świadomie pominięte stany danych — domyślnie empty/loading/error/partial/overflow pokrywa makieta i wzorce design systemu (nie blokuj o domyślne). Mechanika loading (blokada formularza w pending) jest standardem — nie pytaj.
+        # TYLKO FAKT o danych — czy/kiedy stan zachodzi, NIE jak wygląda (render → ui-interactions, int.data-render).
+        # Domyślną kardynalność (empty/partial/overflow) pokrywa makieta; pytaj o świadome ODSTĘPSTWA
+        # (np. „lista nigdy nie jest pusta", nietypowy próg overflow). Mechanika loading (blokada formularza
+        # w pending) jest standardem (forms.md §4) — nie pytaj.
+        q: Fakt o stanach danych — czy zbiór może być pusty, częściowy lub przekroczyć próg liczności (overflow) i kiedy to zachodzi. NIE jak jest renderowany (to ui-interactions). Domyślną kardynalność pokrywa makieta; pytaj o świadome odstępstwa.
         blocking: false
-        source: design-system.md
+        source: functional
+        section: data-states
+      - id: data.loss
+        # SAM FAKT utraty/trwałości danych (decyzja: fakt = stan danych, zachowanie = wizualne → ui-interactions, int.cancel).
+        # Czy istnieją niezapisane dane, czy akcja jest nieodwracalna (destrukcyjna), czy dane mają przetrwać
+        # odświeżenie/powrót czy przepadają. Reakcję aplikacji na ten fakt (potwierdzenie/ostrzeżenie/przywracanie) opisuje ui-interactions.
+        q: Sam fakt możliwej utraty lub trwałości danych — czy operacja/nawigacja/zamknięcie pozostawia niezapisane zmiany, czy akcja jest nieodwracalna, czy dane mają przetrwać odświeżenie/powrót czy przepadają. Reakcję aplikacji na ten fakt opisuje ui-interactions.
+        blocking: false
+        source: functional
         section: data-states
 
   - id: forms
@@ -147,36 +155,32 @@ categories:
         q: Biznesowe reguły inputu — trim/normalizacja wartości, dozwolone znaki, ograniczenia wklejania (gdy odbiegają od domyślnych). NIE pytaj o blokadę formularza w pending — to standard (forms.md §4).
         blocking: false
         source: forms.md
-      - id: forms.generic-errors
-        # BŁĘDY GENERYCZNE (5xx, network, timeout) — REAKCJA JEST STANDARDEM, NIE PYTANIEM.
-        # Należą WYŁĄCZNIE do globalnego interceptora HTTP (type:core); formularz pozostaje
-        # NIEŚWIADOMY (forms.md §6, security.md §2). NIE pytaj analityka, jak obsłużyć 5xx/sieć;
-        # brak wzmianki o 5xx w story = poprawnie (dziedziczone), NIE jest luką.
-        # GUARD (dlatego blocking): jeśli story WIĄŻE reakcję na błąd generyczny z formularzem —
-        # własny komunikat 5xx w widoku, błąd na polu, blokada/odblokowanie CTA, czyszczenie pól
-        # po 5xx/sieci — to KONFLIKT ze standardem (nie wymaganie biznesowe): zgłoś do korekty.
-        # Reakcję W FORMULARZU wywołuje WYŁĄCZNIE błąd domenowy 4xx JAWNIE opisany w story (np. 401
-        # „błędne dane", 403 „konto zablokowane"); 5xx/network/timeout — NIGDY. Globalny notification
-        # (toast aplikacyjny z interceptora) to NIE reakcja formularza — jest zgodny ze standardem.
-        q: (Guard, nie pytanie) Reakcja na błędy generyczne (5xx, network, timeout) jest dziedziczona — globalny interceptor, formularz nieświadomy (forms.md §6); brak wzmianki w story = poprawnie. Jeśli story wiąże reakcję na 5xx/sieć/timeout z formularzem/polem/CTA (własny komunikat w widoku, błąd na polu, blokada przycisku, czyszczenie pól) — to KONFLIKT ze standardem, zgłoś do korekty (nie wymaganie biznesowe). Reakcję formularza wywołuje wyłącznie błąd domenowy 4xx jawnie opisany w story.
-        blocking: true
-        source: forms.md
 
   - id: interactions
     title: Stany i interakcje UI
     section: ui-interactions
     items:
+      - id: int.data-render
+        # CZĘŚĆ WIZUALNA stanów danych (przeniesione z data.states): JAK widok pokazuje empty/loading/error.
+        # Sam FAKT zachodzenia stanu jest w data-states (data.states). Domyślnie pokrywa makieta —
+        # pytaj o świadome odstępstwa/wyłączenia względem niej.
+        q: Jak widok prezentuje stany danych (empty/loading/error) — odstępstwa lub świadome wyłączenia względem makiety. Sam fakt zachodzenia stanu jest w data-states.
+        blocking: false
+        source: design-system.md
       - id: int.states
         # Mechanika stanów (hover/focus/active/disabled/loading) jest DZIEDZICZONA z design systemu.
         q: Które stany interakcji są istotne biznesowo i odstępstwa od domyślnych zachowań design systemu.
         blocking: false
         source: design-system.md
       - id: int.preservation
-        q: Zachowanie stanu przy odświeżeniu/powrocie (formularz, filtry, parametry URL/deep-link).
+        # ZACHOWANIE przywracania stanu (sam fakt „czy stan ma przetrwać" → data-states, data.loss).
+        q: Jak aplikacja przywraca/utrzymuje stan — odtworzenie formularza/filtrów po powrocie, deep-link i parametry URL. Sam fakt, czy stan ma przetrwać, jest w data-states.
         blocking: false
         source: functional
       - id: int.cancel
-        q: Anulowanie akcji, zamknięcie modala, niezapisane zmiany oraz potwierdzenie akcji destrukcyjnych.
+        # ZACHOWANIE aplikacji przy możliwej utracie danych = część wizualna (decyzja z poprzedniej tury);
+        # sam fakt utraty/nieodwracalności → data-states (data.loss).
+        q: Zachowanie aplikacji przy możliwej utracie danych — potwierdzenie zamknięcia/anulowania, ostrzeżenie o niezapisanych zmianach, dialog potwierdzenia akcji destrukcyjnej, blokada nawigacji. Sam fakt utraty/nieodwracalności jest w data-states.
         blocking: false
         source: functional
 
