index 0000000..a6ff09d
--- /dev/null
+++ b/scripts/validators/boundary-tags-validator.js
@@ -0,0 +1,227 @@
+#!/usr/bin/env node
+import { existsSync, readFileSync, readdirSync } from 'fs';
+import path from 'path';
+import { pathToFileURL } from 'url';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Boundary tags validator — sprawdza, czy każdy tag postawiony na projekcie
+ * ma odpowiadającą mu regułę w `@nx/enforce-module-boundaries`, i odwrotnie.
+ *
+ * Reguła granic działa wyłącznie na tagach, które wymieniono w `depConstraints`.
+ * Tag spoza tej listy nie jest „luźniejszy" — on jest po prostu niewidzialny:
+ * projekt, który ma tylko takie tagi, nie ma żadnych ograniczeń zależności,
+ * a lint nic o tym nie powie. To jest cicha dziura, którą to narzędzie wypisuje.
+ *
+ * Wykrywane naruszenia:
+ *   tag-without-rule    — projekt nosi tag, którego żadna reguła nie ma za źródło
+ *                         (błąd — projekt jest poza kontrolą granic na tej osi)
+ *   tag-unknown-in-rule — reguła wymienia tag, którego nie ma żaden projekt
+ *                         (ostrzeżenie — albo literówka, albo zapas na przyszłość)
+ *
+ * Exit code: 0 gdy brak błędów, 1 gdy są, 2 przy błędzie użycia.
+ * Same ostrzeżenia nie zatrzymują przebiegu.
+ *
+ * Użycie:
+ *   node scripts/validators/boundary-tags-validator.js [--format=human|json] [--root=.]
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const BOUNDARIES_RULE = '@nx/enforce-module-boundaries';
+
+/**
+ * Wyciąga `depConstraints` z załadowanej płaskiej konfiguracji ESLinta.
+ * Konfiguracja to tablica bloków; reguła granic może stać w dowolnym z nich,
+ * a jej wartość bywa gołym poziomem błędu bez opcji.
+ *
+ * @param {Array<object>} eslintConfig
+ * @returns {Array<object>|null} null gdy reguły w ogóle nie ma
+ */
+export function collectDepConstraints(eslintConfig) {
+  let found = null;
+
+  for (const block of Array.isArray(eslintConfig) ? eslintConfig : []) {
+    const entry = block?.rules?.[BOUNDARIES_RULE];
+    if (!entry) continue;
+
+    const options = Array.isArray(entry) ? entry[1] : null;
+    const constraints = options?.depConstraints;
+    if (!Array.isArray(constraints)) continue;
+
+    found = [...(found ?? []), ...constraints];
+  }
+
+  return found;
+}
+
+/**
+ * Porównuje tagi projektów z tagami wymienionymi w regułach granic.
+ *
+ * @param {object} args
+ * @param {Array<{project: string, tags: string[]}>} args.projects
+ * @param {Array<object>} args.depConstraints — wpisy z konfiguracji reguły
+ * @returns {Array<{kind: string, severity: 'error'|'warning', subject: string, note: string}>}
+ */
+export function checkTagCoverage({ projects = [], depConstraints = [] }) {
+  const violations = [];
+
+  // Tagi projektów wraz z tym, kto je nosi — nazwy trafiają do komunikatu,
+  // bo bez nich zgłoszenie „tag bez reguły" nie mówi, gdzie szukać.
+  const projectsByTag = new Map();
+  for (const { project, tags } of projects) {
+    for (const tag of Array.isArray(tags) ? tags : []) {
+      if (!projectsByTag.has(tag)) projectsByTag.set(tag, []);
+      projectsByTag.get(tag).push(project);
+    }
+  }
+
+  const sourceTags = new Set();
+  const targetTags = new Set();
+  for (const constraint of depConstraints) {
+    for (const tag of asArray(constraint?.sourceTag).concat(asArray(constraint?.allSourceTags))) {
+      sourceTags.add(tag);
+    }
+    for (const tag of asArray(constraint?.onlyDependOnLibsWithTags).concat(asArray(constraint?.notDependOnLibsWithTags))) {
+      targetTags.add(tag);
+    }
+  }
+
+  for (const [tag, owners] of [...projectsByTag].sort()) {
+    if (sourceTags.has(tag)) continue;
+    violations.push({
+      kind: 'tag-without-rule',
+      severity: 'error',
+      subject: tag,
+      note:
+        `Żadna reguła granic nie ma tego tagu za źródło, więc nie ogranicza projektów, które go noszą: ${owners.join(', ')}.`,
+    });
+  }
+
+  // Zbiór, nie sklejone listy: tag stojący i po stronie źródła, i po stronie
+  // dozwolonych zależności zgłosiłby się wtedy dwa razy.
+  for (const tag of [...new Set([...sourceTags, ...targetTags])].sort()) {
+    if (projectsByTag.has(tag)) continue;
+    const role = sourceTags.has(tag) ? 'jako źródło' : 'na liście dozwolonych zależności';
+    violations.push({
+      kind: 'tag-unknown-in-rule',
+      severity: 'warning',
+      subject: tag,
+      note: `Reguła granic wymienia ten tag ${role}, a nie nosi go żaden projekt.`,
+    });
+  }
+
+  return violations;
+}
+
+function asArray(value) {
+  if (Array.isArray(value)) return value;
+  return typeof value === 'string' && value ? [value] : [];
+}
+
+/* ── Powłoka CLI ───────────────────────────────────────────────────────────── */
+
+/** Wszystkie projekty w drzewie — projekt = katalog z project.json. */
+function collectProjects(root, bases) {
+  const results = [];
+
+  function walk(directory) {
+    let entries;
+    try {
+      entries = readdirSync(directory, { withFileTypes: true });
+    } catch {
+      return;
+    }
+
+    if (entries.some((entry) => entry.isFile() && entry.name === 'project.json')) {
+      results.push(directory);
+      return;
+    }
+
+    for (const entry of entries) {
+      if (!entry.isDirectory() || entry.name === 'node_modules' || entry.name.startsWith('.')) continue;
+      walk(path.join(directory, entry.name));
+    }
+  }
+
+  for (const base of bases) walk(path.join(root, base));
+  return results;
+}
+
+function parseArgs(argv) {
+  const args = {};
+  for (const token of argv) {
+    const match = /^--([\w-]+)(?:=(.*))?$/.exec(token);
+    if (match) args[match[1]] = match[2] ?? true;
+  }
+  return args;
+}
+
+function printHuman({ projects_checked, constraints_checked, violations }) {
+  console.log(`boundary-tags-validator — sprawdzono ${projects_checked} projektów, ${constraints_checked} reguł granic`);
+
+  const errors = violations.filter((violation) => violation.severity === 'error');
+  const warnings = violations.filter((violation) => violation.severity === 'warning');
+
+  if (violations.length === 0) {
+    console.log('✓ Każdy tag ma regułę, każda reguła ma projekt.');
+    return;
+  }
+
+  if (errors.length) {
+    console.log(`\n✗ Tagi bez reguły: ${errors.length}\n`);
+    for (const item of errors) console.log(`  ${item.subject}\n    ${item.note}\n`);
+  }
+
+  if (warnings.length) {
+    console.log(`⚠ Tagi wymienione w regułach, których nikt nie nosi: ${warnings.length}\n`);
+    for (const item of warnings) console.log(`  ${item.subject}\n    ${item.note}\n`);
+  }
+}
+
+async function main() {
+  const args = parseArgs(process.argv.slice(2));
+  const root = path.resolve(args.root || '.');
+  const format = args.format || 'human';
+
+  const configPath = path.join(root, 'eslint.config.mjs');
+  if (!existsSync(configPath)) {
+    process.stderr.write(`boundary-tags-validator: brak eslint.config.mjs w ${root}\n`);
+    process.exit(2);
+  }
+
+  // Konfiguracja jest modułem, więc czytamy ją uruchomieniem, a nie parsowaniem
+  // tekstu — inaczej każda zmiana zapisu reguły (stała, spread, funkcja) myliłaby
+  // walidator.
+  const imported = await import(pathToFileURL(configPath).href);
+  const depConstraints = collectDepConstraints(imported.default);
+  if (!depConstraints) {
+    process.stderr.write(`boundary-tags-validator: w eslint.config.mjs nie ma reguły ${BOUNDARIES_RULE} z depConstraints\n`);
+    process.exit(2);
+  }
+
+  const projects = collectProjects(root, ['apps', 'libs']).map((directory) => {
+    const projectJson = JSON.parse(readFileSync(path.join(directory, 'project.json'), 'utf-8'));
+    return {
+      project: projectJson.name ?? path.relative(root, directory).split(path.sep).join('/'),
+      tags: projectJson.tags ?? [],
+    };
+  });
+
+  const violations = checkTagCoverage({ projects, depConstraints });
+  const report = {
+    root,
+    projects_checked: projects.length,
+    constraints_checked: depConstraints.length,
+    violations_count: violations.length,
+    violations,
+  };
+
+  if (format === 'json') console.log(JSON.stringify(report, null, 2));
+  else printHuman(report);
+
+  process.exit(violations.some((violation) => violation.severity === 'error') ? 1 : 0);
+}
+
+// Powłoka rusza wyłącznie przy bezpośrednim uruchomieniu — import w teście
+// ma dać czyste funkcje, nie wywołać CLI i nie ubić procesu przez process.exit.
+if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
+  await main();
+}
diff --git b/scripts/validators/boundary-tags-validator.test.js b/scripts/validators/boundary-tags-validator.test.js
new file mode 100644
index 0000000..5a931fd
--- /dev/null
+++ b/scripts/validators/boundary-tags-validator.test.js
@@ -0,0 +1,82 @@
+import assert from 'node:assert/strict';
+import { test } from 'node:test';
+
+import { checkTagCoverage, collectDepConstraints } from './boundary-tags-validator.js';
+
+const kinds = (violations) => violations.map((violation) => violation.kind);
+
+/* ── collectDepConstraints ─────────────────────────────────────────────────── */
+
+test('collectDepConstraints: znajduje regułę w dowolnym bloku konfiguracji', () => {
+  const config = [
+    { rules: { 'no-console': 'error' } },
+    { rules: { '@nx/enforce-module-boundaries': ['error', { depConstraints: [{ sourceTag: 'type:ui', onlyDependOnLibsWithTags: [] }] }] } },
+  ];
+
+  assert.deepEqual(collectDepConstraints(config), [{ sourceTag: 'type:ui', onlyDependOnLibsWithTags: [] }]);
+});
+
+test('collectDepConstraints: reguła bez opcji oraz brak reguły', () => {
+  assert.equal(collectDepConstraints([{ rules: { '@nx/enforce-module-boundaries': 'error' } }]), null);
+  assert.equal(collectDepConstraints([{ rules: {} }]), null);
+  assert.equal(collectDepConstraints(null), null);
+});
+
+/* ── checkTagCoverage ──────────────────────────────────────────────────────── */
+
+const PROJEKTY = [
+  { project: 'shared-common-util', tags: ['scope:shared', 'type:util', 'context:common'] },
+  { project: 'frontend-app', tags: ['scope:frontend-app', 'type:app'] },
+];
+
+const REGULY = [
+  { sourceTag: 'scope:shared', onlyDependOnLibsWithTags: ['scope:shared'] },
+  { sourceTag: 'scope:frontend-app', onlyDependOnLibsWithTags: ['scope:frontend-app', 'scope:shared'] },
+  { sourceTag: 'context:common', onlyDependOnLibsWithTags: ['context:common'] },
+  { sourceTag: 'type:util', onlyDependOnLibsWithTags: ['type:util'] },
+  { sourceTag: 'type:app', onlyDependOnLibsWithTags: ['type:util'] },
+];
+
+test('komplet tagów i reguł nie daje naruszeń', () => {
+  assert.deepEqual(checkTagCoverage({ projects: PROJEKTY, depConstraints: REGULY }), []);
+});
+
+test('tag noszony przez projekt bez odpowiadającej reguły to błąd, z nazwami projektów', () => {
+  const projects = [...PROJEKTY, { project: 'frontend-app-e2e', tags: ['scope:frontend-app', 'type:e2e'] }];
+  const violations = checkTagCoverage({ projects, depConstraints: REGULY });
+
+  assert.deepEqual(kinds(violations), ['tag-without-rule']);
+  assert.equal(violations[0].severity, 'error');
+  assert.equal(violations[0].subject, 'type:e2e');
+  assert.match(violations[0].note, /frontend-app-e2e/);
+});
+
+test('tag z reguły, którego nikt nie nosi, to ostrzeżenie', () => {
+  const depConstraints = [...REGULY, { sourceTag: 'context:billing', onlyDependOnLibsWithTags: ['context:billing'] }];
+  const violations = checkTagCoverage({ projects: PROJEKTY, depConstraints });
+
+  assert.deepEqual(kinds(violations), ['tag-unknown-in-rule']);
+  assert.equal(violations[0].severity, 'warning');
+  assert.equal(violations[0].subject, 'context:billing');
+});
+
+test('tag stojący po obu stronach reguły zgłasza się raz', () => {
+  const depConstraints = [{ sourceTag: 'type:model', onlyDependOnLibsWithTags: ['type:model'] }];
+  const violations = checkTagCoverage({ projects: [], depConstraints });
+
+  assert.deepEqual(violations.map((violation) => violation.subject), ['type:model']);
+});
+
+test('allSourceTags oraz notDependOnLibsWithTags są brane pod uwagę', () => {
+  const depConstraints = [
+    { allSourceTags: ['type:util', 'scope:shared'], notDependOnLibsWithTags: ['type:feature'] },
+    { sourceTag: 'context:common', onlyDependOnLibsWithTags: ['context:common'] },
+    { sourceTag: 'scope:frontend-app', onlyDependOnLibsWithTags: [] },
+    { sourceTag: 'type:app', onlyDependOnLibsWithTags: [] },
+  ];
+  const violations = checkTagCoverage({ projects: PROJEKTY, depConstraints });
+
+  // Zostaje wyłącznie tag z listy zakazanych zależności — nie nosi go żaden projekt.
+  assert.deepEqual(kinds(violations), ['tag-unknown-in-rule']);
+  assert.equal(violations[0].subject, 'type:feature');
+});
diff --git b/scripts/validators/library-naming-validator.js b/scripts/validators/library-naming-validator.js
new file mode 100644
index 0000000..f7a6987
--- /dev/null
+++ b/scripts/validators/library-naming-validator.js
@@ -0,0 +1,481 @@
+#!/usr/bin/env node
+import { readFileSync, existsSync, readdirSync } from 'fs';
+import path from 'path';
+import { pathToFileURL } from 'url';
+
+import { deriveLibraryNaming } from '../generators/utils/library-naming.js';
+import { LIBRARY_NAMING } from '../generators/utils/naming-config.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Library naming validator — sprawdza, czy nazwa projektu, alias importu i tagi
+ * zgadzają się z miejscem, w którym biblioteka leży.
+ *
+ * Źródłem prawdy jest KATALOG. Z jego ścieżki derywuje się kanoniczna trójka
+ * (scope, kontekst, typ) i z niej — tą samą funkcją, której używa generator —
+ * nazwa projektu, alias i katalog. Wszystko pozostałe musi się do tego dostroić.
+ * Dzięki temu walidator i generator nie mogą się rozjechać.
+ *
+ * Wzorzec katalogu i aliasu (docs/standards/nx.md):
+ *   `<basePath>/<kontekst>/<typ>[/<nazwa>]`, typ w liczbie pojedynczej,
+ *   kontekst zawsze przed typem, brak <nazwy> = biblioteka-barrel typu.
+ *
+ * Wykrywane naruszenia — biblioteka:
+ *   directory-shape-invalid  — ścieżki nie da się rozebrać na kontekst/typ[/nazwę]
+ *   directory-plural-type    — segment ścieżki w liczbie mnogiej
+ *   directory-type-unknown   — na pozycji typu stoi coś, co typem nie jest
+ *   project-json-missing     — katalog biblioteki bez project.json
+ *   project-name-mismatch    — nazwa projektu ≠ nazwa wynikająca z położenia
+ *   project-tag-missing      — brak tagu scope:, type: albo context:
+ *   project-tag-mismatch     — tag mówi co innego niż położenie
+ *   alias-missing            — żaden alias nie prowadzi do tej biblioteki
+ *
+ * Wykrywane naruszenia — alias:
+ *   alias-path-missing       — alias wskazuje na nieistniejący katalog
+ *   alias-directory-mismatch — alias wskazuje na katalog, który nazywa się inaczej
+ *
+ * Wykrywane naruszenia — aplikacja:
+ *   app-name-mismatch        — nazwa projektu ≠ nazwa katalogu
+ *   app-tag-missing          — brak tagu scope: albo type:
+ *   app-tag-mismatch         — tag mówi co innego niż katalog
+ *   app-prefix-missing       — aplikacja nie deklaruje `prefix`
+ *
+ * Brak `prefix` jest błędem, a nie drobiazgiem: to z niego derywują się aliasy
+ * wszystkich bibliotek tej aplikacji, a derywacja po cichu spada wtedy na
+ * prefiks współdzielony i produkuje aliasy wyglądające na poprawne.
+ *
+ * Exit code: 0 gdy zero naruszeń, 1 gdy są, 2 przy błędzie użycia.
+ *
+ * Użycie:
+ *   node scripts/validators/library-naming-validator.js [--format=human|json] [--root=.]
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+const ALLOWED_TYPES = ['feature', 'state', 'ui', 'core', 'model', 'util', 'asset'];
+
+const PLURAL_OF = {
+  features: 'feature',
+  states: 'state',
+  uis: 'ui',
+  cores: 'core',
+  models: 'model',
+  utils: 'util',
+  assets: 'asset',
+};
+
+/** Sufiks katalogu projektu testów przeglądarkowych — rządzi się własnym typem. */
+const E2E_SUFFIX = '-e2e';
+
+/**
+ * Rozbiera ścieżkę katalogu biblioteki na trójkę strukturalną.
+ * Rozpoznaje oba układy: biblioteki współdzielone leżą pod `sharedBase`,
+ * biblioteki aplikacji pod `appsBase/<aplikacja>`.
+ *
+ * @param {string} directory — ścieżka względem korzenia repozytorium, ukośniki `/`
+ * @param {object} [naming] — override LIBRARY_NAMING
+ * @returns {{scope: string, context: string, type: string, segment: string|null}|null}
+ *          null gdy ścieżka nie pasuje do żadnego układu albo ma złą liczbę segmentów
+ */
+export function parseLibraryDirectory(directory, naming = {}) {
+  const config = { ...LIBRARY_NAMING, ...naming };
+  const segments = String(directory ?? '').split('/').filter(Boolean);
+
+  const sharedBase = config.sharedBase.split('/');
+  const appsBase = config.appsBase.split('/');
+
+  let scope = null;
+  let rest = null;
+
+  if (startsWith(segments, sharedBase)) {
+    scope = config.sharedScope;
+    rest = segments.slice(sharedBase.length);
+  } else if (startsWith(segments, appsBase) && segments.length > appsBase.length) {
+    scope = segments[appsBase.length];
+    rest = segments.slice(appsBase.length + 1);
+  } else {
+    return null;
+  }
+
+  // Dozwolone są dwa kształty: `<kontekst>/<typ>` oraz `<kontekst>/<typ>/<nazwa>`.
+  if (rest.length < 2 || rest.length > 3) return null;
+
+  return { scope, context: rest[0], type: rest[1], segment: rest[2] ?? null };
+}
+
+/**
+ * Sprawdza cały workspace na podstawie zebranego zrzutu — bez dotykania dysku,
+ * żeby dało się to testować na danych podstawionych.
+ *
+ * @param {object} args
+ * @param {Array<{directory: string, projectJson: object|null}>} args.libraries
+ *        katalogi bibliotek wraz z treścią ich project.json (null gdy pliku nie ma)
+ * @param {Array<{directory: string, projectJson: object}>} args.applications
+ *        katalogi aplikacji wraz z treścią ich project.json
+ * @param {Array<{alias: string, targetDirectory: string|null}>} args.aliases
+ *        aliasy z tsconfig.base.json; targetDirectory = null gdy cel nie istnieje
+ * @param {object} [args.naming] — override LIBRARY_NAMING; musi nieść `prefixByScope`,
+ *        inaczej derywacja aliasu sięgnie po prefiks na dysk
+ * @returns {Array<{kind: string, subject: string, note: string}>}
+ */
+export function checkWorkspaceNaming({ libraries = [], applications = [], aliases = [], naming = {} }) {
+  const config = { ...LIBRARY_NAMING, ...naming };
+  const violations = [];
+
+  // Alias → katalog, i odwrotnie: katalog → jego kanoniczna postać. Oba indeksy
+  // powstają przed sprawdzeniami, bo każda ze stron pyta o drugą.
+  const aliasesByDirectory = new Map();
+  for (const { alias, targetDirectory } of aliases) {
+    if (!targetDirectory) continue;
+    if (!aliasesByDirectory.has(targetDirectory)) aliasesByDirectory.set(targetDirectory, []);
+    aliasesByDirectory.get(targetDirectory).push(alias);
+  }
+
+  const canonicalByDirectory = new Map();
+
+  for (const library of libraries) {
+    violations.push(...checkLibrary(library, { config, aliasesByDirectory, canonicalByDirectory }));
+  }
+
+  for (const alias of aliases) {
+    violations.push(...checkAlias(alias, canonicalByDirectory));
+  }
+
+  for (const application of applications) {
+    violations.push(...checkApplication(application));
+  }
+
+  return violations;
+}
+
+/**
+ * Sprawdza jedną bibliotekę: kształt ścieżki, nazwę projektu, tagi i alias.
+ * Zapisuje przy okazji kanoniczną postać katalogu do indeksu współdzielonego
+ * ze sprawdzeniem aliasów.
+ */
+function checkLibrary({ directory, projectJson }, { config, aliasesByDirectory, canonicalByDirectory }) {
+  const violations = [];
+  const report = (kind, note) => violations.push({ kind, subject: directory, note });
+
+  for (const segment of directory.split('/')) {
+    if (PLURAL_OF[segment]) {
+      report('directory-plural-type', `Segment "${segment}/" jest w liczbie mnogiej — powinno być "${PLURAL_OF[segment]}/".`);
+    }
+  }
+
+  const location = parseLibraryDirectory(directory, config);
+  if (!location) {
+    report(
+      'directory-shape-invalid',
+      `Ścieżki nie da się rozebrać na "<kontekst>/<typ>[/<nazwa>]" pod ${config.sharedBase}/ ani ${config.appsBase}/<aplikacja>/.`,
+    );
+    return violations;
+  }
+
+  if (!ALLOWED_TYPES.includes(location.type)) {
+    report(
+      'directory-type-unknown',
+      `Na pozycji typu stoi "${location.type}", a dozwolone są [${ALLOWED_TYPES.join(', ')}]. ` +
+        'Najczęstsza przyczyna to odwrócona kolejność — wymagane jest "<kontekst>/<typ>".',
+    );
+    return violations;
+  }
+
+  const canonical = deriveLibraryNaming(
+    { scope: location.scope, tag: location.type, domain: location.context, segment: location.segment },
+    config,
+  );
+  canonicalByDirectory.set(directory, canonical);
+
+  if (!projectJson) {
+    report('project-json-missing', 'Katalog wygląda na bibliotekę, ale nie ma w nim project.json.');
+  } else {
+    if (projectJson.name !== canonical.name) {
+      report('project-name-mismatch', `Projekt nazywa się "${projectJson.name}", a z położenia wynika "${canonical.name}".`);
+    }
+    violations.push(...checkTags(projectJson.tags, { scope: location.scope, type: location.type, context: location.context }, directory));
+  }
+
+  const registered = aliasesByDirectory.get(directory) ?? [];
+  if (!registered.includes(canonical.importPath)) {
+    const found = registered.length ? `Znalezione: ${registered.join(', ')}.` : 'Nie ma żadnego aliasu prowadzącego do tego katalogu.';
+    report('alias-missing', `Brak aliasu "${canonical.importPath}" w tsconfig.base.json. ${found}`);
+  }
+
+  return violations;
+}
+
+/**
+ * Sprawdza, czy alias prowadzi do katalogu, który faktycznie się tak nazywa.
+ * To jedyne miejsce, które łapie aliasy wskazujące na cudzą bibliotekę —
+ * samo istnienie celu niczego nie dowodzi.
+ */
+function checkAlias({ alias, targetDirectory }, canonicalByDirectory) {
+  if (!targetDirectory) {
+    return [{ kind: 'alias-path-missing', subject: alias, note: 'Alias wskazuje na katalog, którego nie ma na dysku.' }];
+  }
+
+  const canonical = canonicalByDirectory.get(targetDirectory);
+  if (!canonical) {
+    return [
+      {
+        kind: 'alias-directory-mismatch',
+        subject: alias,
+        note: `Alias wskazuje na "${targetDirectory}", a to nie jest biblioteka o poprawnym położeniu.`,
+      },
+    ];
+  }
+
+  if (canonical.importPath !== alias) {
+    return [
+      {
+        kind: 'alias-directory-mismatch',
+        subject: alias,
+        note: `Alias wskazuje na "${targetDirectory}", którego kanoniczny alias to "${canonical.importPath}".`,
+      },
+    ];
+  }
+
+  return [];
+}
+
+/**
+ * Sprawdza aplikację: nazwę, tagi i zadeklarowany prefiks. Projekt testów
+ * przeglądarkowych rozpoznaje po sufiksie katalogu — należy do scope aplikacji,
+ * którą testuje, i nie derywuje aliasów, więc prefiksu nie potrzebuje.
+ */
+function checkApplication({ directory, projectJson }) {
+  const violations = [];
+  const name = directory.split('/').pop();
+  const isE2e = name.endsWith(E2E_SUFFIX);
+  const expected = {
+    scope: isE2e ? name.slice(0, -E2E_SUFFIX.length) : name,
+    type: isE2e ? 'e2e' : 'app',
+  };
+
+  if (projectJson.name !== name) {
+    violations.push({
+      kind: 'app-name-mismatch',
+      subject: directory,
+      note: `Projekt nazywa się "${projectJson.name}", a katalog "${name}".`,
+    });
+  }
+
+  violations.push(...checkTags(projectJson.tags, expected, directory, { kindPrefix: 'app' }));
+
+  if (!isE2e && !String(projectJson.prefix ?? '').trim()) {
+    violations.push({
+      kind: 'app-prefix-missing',
+      subject: directory,
+      note: 'Aplikacja nie deklaruje pola "prefix", z którego derywują się aliasy jej bibliotek.',
+    });
+  }
+
+  return violations;
+}
+
+/**
+ * Porównuje tagi projektu z wartościami wynikającymi z jego położenia.
+ * Osie nieobecne w `expected` (np. context dla aplikacji) nie są sprawdzane.
+ */
+function checkTags(tags, expected, subject, { kindPrefix = 'project' } = {}) {
+  const violations = [];
+  const present = new Map();
+  for (const tag of Array.isArray(tags) ? tags : []) {
+    const [axis, ...value] = String(tag).split(':');
+    if (value.length) present.set(axis, value.join(':'));
+  }
+
+  for (const [axis, value] of Object.entries(expected)) {
+    if (!present.has(axis)) {
+      violations.push({ kind: `${kindPrefix}-tag-missing`, subject, note: `Brak tagu "${axis}:${value}".` });
+    } else if (present.get(axis) !== value) {
+      violations.push({
+        kind: `${kindPrefix}-tag-mismatch`,
+        subject,
+        note: `Tag mówi "${axis}:${present.get(axis)}", a z położenia wynika "${axis}:${value}".`,
+      });
+    }
+  }
+
+  return violations;
+}
+
+function startsWith(segments, prefix) {
+  return prefix.every((segment, index) => segments[index] === segment);
+}
+
+/* ── Powłoka CLI ───────────────────────────────────────────────────────────── */
+
+/** Katalogi projektów pod danym korzeniem — projekt = katalog z project.json. */
+function collectProjects(root) {
+  const results = [];
+
+  function walk(directory) {
+    let entries;
+    try {
+      entries = readdirSync(directory, { withFileTypes: true });
+    } catch {
+      return;
+    }
+
+    if (entries.some((entry) => entry.isFile() && entry.name === 'project.json')) {
+      results.push(directory);
+      return;
+    }
+
+    for (const entry of entries) {
+      if (!entry.isDirectory() || entry.name === 'node_modules' || entry.name.startsWith('.')) continue;
+      walk(path.join(directory, entry.name));
+    }
+  }
+
+  walk(root);
+  return results;
+}
+
+/**
+ * Katalogi bibliotek widziane po samym dysku — katalog z `src/`, bez schodzenia
+ * głębiej. Łapie też bibliotekę bez project.json, której `collectProjects` nie widzi.
+ */
+function collectLibraryDirectories(libsRoot) {
+  const results = [];
+
+  function walk(directory) {
+    let entries;
+    try {
+      entries = readdirSync(directory, { withFileTypes: true });
+    } catch {
+      return;
+    }
+
+    if (entries.some((entry) => entry.isDirectory() && entry.name === 'src')) {
+      results.push(directory);
+      return;
+    }
+
+    for (const entry of entries) {
+      if (!entry.isDirectory() || entry.name === 'node_modules' || entry.name.startsWith('.')) continue;
+      walk(path.join(directory, entry.name));
+    }
+  }
+
+  walk(libsRoot);
+  return results;
+}
+
+function toPosix(root, absolute) {
+  return path.relative(root, absolute).split(path.sep).join('/');
+}
+
+function readJsonIfExists(filePath) {
+  if (!existsSync(filePath)) return null;
+  try {
+    // tsconfig i project.json bywają z komentarzami — te są tu bez znaczenia,
+    // więc wycinamy je zamiast wciągać parser JSONC.
+    const text = readFileSync(filePath, 'utf-8')
+      .replace(/\/\*[\s\S]*?\*\//g, '')
+      .replace(/^\s*\/\/.*$/gm, '');
+    return JSON.parse(text);
+  } catch {
+    return null;
+  }
+}
+
+function parseArgs(argv) {
+  const args = {};
+  for (const token of argv) {
+    const match = /^--([\w-]+)(?:=(.*))?$/.exec(token);
+    if (match) args[match[1]] = match[2] ?? true;
+  }
+  return args;
+}
+
+function printHuman({ libraries_checked, applications_checked, aliases_checked, violations }) {
+  console.log(
+    `library-naming-validator — sprawdzono ${libraries_checked} bibliotek, ` +
+      `${applications_checked} aplikacji, ${aliases_checked} aliasów`,
+  );
+
+  if (violations.length === 0) {
+    console.log('✓ Nazwy, aliasy i tagi zgadzają się z położeniem.');
+    return;
+  }
+
+  const bySubject = new Map();
+  for (const item of violations) {
+    if (!bySubject.has(item.subject)) bySubject.set(item.subject, []);
+    bySubject.get(item.subject).push(item);
+  }
+
+  console.log(`✗ Naruszeń: ${violations.length} w ${bySubject.size} miejscach\n`);
+  for (const [subject, items] of bySubject) {
+    console.log(`  ${subject}`);
+    for (const item of items) console.log(`    - [${item.kind}] ${item.note}`);
+    console.log();
+  }
+}
+
+function main() {
+  const args = parseArgs(process.argv.slice(2));
+  const root = path.resolve(args.root || '.');
+  const format = args.format || 'human';
+
+  const tsconfig = readJsonIfExists(path.join(root, 'tsconfig.base.json'));
+  if (!tsconfig) {
+    process.stderr.write(`library-naming-validator: brak czytelnego tsconfig.base.json w ${root}\n`);
+    process.exit(2);
+  }
+
+  const libsRoot = path.join(root, LIBRARY_NAMING.sharedBase.split('/')[0]);
+  const appsRoot = path.join(root, LIBRARY_NAMING.appProjectsBase);
+
+  const applications = collectProjects(appsRoot).map((directory) => ({
+    directory: toPosix(root, directory),
+    projectJson: readJsonIfExists(path.join(directory, 'project.json')) ?? {},
+  }));
+
+  // Prefiks per scope czytany raz, z workspace — derywacja aliasów nie może
+  // dobierać go sama, bo brak deklaracji przy aplikacji ma być zgłoszony, a nie
+  // po cichu zastąpiony prefiksem współdzielonym.
+  const prefixByScope = {};
+  for (const application of applications) {
+    const name = application.directory.split('/').pop();
+    if (typeof application.projectJson.prefix === 'string' && application.projectJson.prefix.trim()) {
+      prefixByScope[name] = application.projectJson.prefix.trim();
+    }
+  }
+
+  const libraries = collectLibraryDirectories(libsRoot).map((directory) => ({
+    directory: toPosix(root, directory),
+    projectJson: readJsonIfExists(path.join(directory, 'project.json')),
+  }));
+
+  const aliases = Object.entries(tsconfig?.compilerOptions?.paths ?? {}).map(([alias, targets]) => {
+    const target = Array.isArray(targets) ? targets[0] : targets;
+    const absolute = path.resolve(root, String(target).replace(/^\.\//, ''));
+    // Alias celuje w plik `src/index.ts`, a porównujemy katalogi bibliotek,
+    // więc schodzimy z pliku i z `src/` do korzenia biblioteki.
+    const directory = path.dirname(absolute).replace(new RegExp(`\\${path.sep}src$`), '');
+    return { alias, targetDirectory: existsSync(directory) ? toPosix(root, directory) : null };
+  });
+
+  const violations = checkWorkspaceNaming({ libraries, applications, aliases, naming: { ...LIBRARY_NAMING, prefixByScope } });
+
+  const report = {
+    root,
+    libraries_checked: libraries.length,
+    applications_checked: applications.length,
+    aliases_checked: aliases.length,
+    violations_count: violations.length,
+    violations,
+  };
+
+  if (format === 'json') console.log(JSON.stringify(report, null, 2));
+  else printHuman(report);
+
+  process.exit(violations.length === 0 ? 0 : 1);
+}
+
+// Powłoka rusza wyłącznie przy bezpośrednim uruchomieniu — import w teście
+// ma dać czyste funkcje, nie wywołać CLI i nie ubić procesu przez process.exit.
+if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
+  main();
+}
diff --git b/scripts/validators/library-naming-validator.test.js b/scripts/validators/library-naming-validator.test.js
new file mode 100644
index 0000000..999e10b
--- /dev/null
+++ b/scripts/validators/library-naming-validator.test.js
@@ -0,0 +1,168 @@
+import assert from 'node:assert/strict';
+import { test } from 'node:test';
+
+import { LIBRARY_NAMING } from '../generators/utils/naming-config.js';
+import { checkWorkspaceNaming, parseLibraryDirectory } from './library-naming-validator.js';
+
+/** Prefiksy podstawione wprost, żeby derywacja nie schodziła po nie na dysk. */
+const NAMING = { ...LIBRARY_NAMING, prefixByScope: { 'frontend-app': 'gdprrt-app' } };
+
+const kinds = (violations) => violations.map((violation) => violation.kind);
+
+/** Workspace w kształcie, który ma przechodzić bez uwag. */
+function poprawnyWorkspace() {
+  return {
+    libraries: [
+      {
+        directory: 'libs/shared/common/util',
+        projectJson: { name: 'shared-common-util', tags: ['scope:shared', 'type:util', 'context:common'] },
+      },
+      {
+        directory: 'libs/apps/frontend-app/auth/core',
+        projectJson: { name: 'frontend-app-auth-core', tags: ['scope:frontend-app', 'type:core', 'context:auth'] },
+      },
+    ],
+    applications: [
+      { directory: 'apps/frontend-app', projectJson: { name: 'frontend-app', tags: ['scope:frontend-app', 'type:app'], prefix: 'gdprrt-app' } },
+    ],
+    aliases: [
+      { alias: '@gdprrt/shared/common/util', targetDirectory: 'libs/shared/common/util' },
+      { alias: '@gdprrt-app/auth/core', targetDirectory: 'libs/apps/frontend-app/auth/core' },
+    ],
+    naming: NAMING,
+  };
+}
+
+/* ── parseLibraryDirectory ─────────────────────────────────────────────────── */
+
+test('parseLibraryDirectory: oba układy katalogów', () => {
+  assert.deepEqual(parseLibraryDirectory('libs/shared/common/util'), {
+    scope: 'shared',
+    context: 'common',
+    type: 'util',
+    segment: null,
+  });
+
+  assert.deepEqual(parseLibraryDirectory('libs/shared/common/core/api'), {
+    scope: 'shared',
+    context: 'common',
+    type: 'core',
+    segment: 'api',
+  });
+
+  assert.deepEqual(parseLibraryDirectory('libs/apps/frontend-app/auth/core'), {
+    scope: 'frontend-app',
+    context: 'auth',
+    type: 'core',
+    segment: null,
+  });
+});
+
+test('parseLibraryDirectory: za mało i za dużo segmentów oraz obcy korzeń', () => {
+  assert.equal(parseLibraryDirectory('libs/shared/util'), null);
+  assert.equal(parseLibraryDirectory('libs/shared/common/core/api/extra'), null);
+  assert.equal(parseLibraryDirectory('packages/shared/common/util'), null);
+});
+
+/* ── checkWorkspaceNaming ──────────────────────────────────────────────────── */
+
+test('poprawny workspace nie daje naruszeń', () => {
+  assert.deepEqual(checkWorkspaceNaming(poprawnyWorkspace()), []);
+});
+
+test('alias wskazujący na cudzy katalog jest wykrywany po obu stronach', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.libraries.push({
+    directory: 'libs/shared/common/model',
+    projectJson: { name: 'shared-common-model', tags: ['scope:shared', 'type:model', 'context:common'] },
+  });
+  // Dwa aliasy zamienione miejscami: każdy cel istnieje i każdy katalog ma alias,
+  // więc samo sprawdzenie istnienia niczego by tu nie wykryło.
+  workspace.aliases[0] = { alias: '@gdprrt/shared/common/util', targetDirectory: 'libs/shared/common/model' };
+  workspace.aliases.push({ alias: '@gdprrt/shared/common/model', targetDirectory: 'libs/shared/common/util' });
+
+  const violations = checkWorkspaceNaming(workspace);
+
+  assert.deepEqual(kinds(violations).sort(), ['alias-directory-mismatch', 'alias-directory-mismatch', 'alias-missing', 'alias-missing']);
+  assert.match(
+    violations.find((violation) => violation.subject === '@gdprrt/shared/common/util').note,
+    /kanoniczny alias to "@gdprrt\/shared\/common\/model"/,
+  );
+});
+
+test('alias na nieistniejący katalog', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.aliases.push({ alias: '@gdprrt/shared/common/asset', targetDirectory: null });
+
+  assert.deepEqual(kinds(checkWorkspaceNaming(workspace)), ['alias-path-missing']);
+});
+
+test('biblioteka bez aliasu', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.aliases.shift();
+
+  const violations = checkWorkspaceNaming(workspace);
+  assert.deepEqual(kinds(violations), ['alias-missing']);
+  assert.match(violations[0].note, /@gdprrt\/shared\/common\/util/);
+});
+
+test('nazwa projektu rozjechana z położeniem', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.libraries[0].projectJson.name = 'shared-util';
+
+  const violations = checkWorkspaceNaming(workspace);
+  assert.deepEqual(kinds(violations), ['project-name-mismatch']);
+  assert.match(violations[0].note, /"shared-util".*"shared-common-util"/);
+});
+
+test('tagi: brak osi oraz wartość niezgodna z położeniem', () => {
+  const brak = poprawnyWorkspace();
+  brak.libraries[0].projectJson.tags = ['scope:shared', 'type:util'];
+  assert.deepEqual(kinds(checkWorkspaceNaming(brak)), ['project-tag-missing']);
+
+  const rozjazd = poprawnyWorkspace();
+  rozjazd.libraries[0].projectJson.tags = ['scope:shared', 'type:feature', 'context:common'];
+  const violations = checkWorkspaceNaming(rozjazd);
+  assert.deepEqual(kinds(violations), ['project-tag-mismatch']);
+  assert.match(violations[0].note, /"type:feature".*"type:util"/);
+});
+
+test('katalog w liczbie mnogiej oraz odwrócona kolejność kontekst/typ', () => {
+  const mnoga = poprawnyWorkspace();
+  mnoga.libraries = [{ directory: 'libs/shared/common/utils', projectJson: null }];
+  mnoga.aliases = [];
+  assert.ok(kinds(checkWorkspaceNaming(mnoga)).includes('directory-plural-type'));
+
+  const odwrocona = poprawnyWorkspace();
+  odwrocona.libraries = [{ directory: 'libs/apps/frontend-app/core/auth', projectJson: null }];
+  odwrocona.aliases = [];
+  assert.deepEqual(kinds(checkWorkspaceNaming(odwrocona)), ['directory-type-unknown']);
+});
+
+test('katalog biblioteki bez project.json', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.libraries[0].projectJson = null;
+
+  assert.deepEqual(kinds(checkWorkspaceNaming(workspace)), ['project-json-missing']);
+});
+
+test('aplikacja: nazwa, tagi i brak prefiksu', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.applications = [{ directory: 'apps/frontend-app', projectJson: { name: 'app', tags: ['type:app'] } }];
+
+  assert.deepEqual(kinds(checkWorkspaceNaming(workspace)).sort(), [
+    'app-name-mismatch',
+    'app-prefix-missing',
+    'app-tag-missing',
+  ]);
+});
+
+test('aplikacja testów przeglądarkowych: własny typ, scope testowanej aplikacji, bez prefiksu', () => {
+  const workspace = poprawnyWorkspace();
+  workspace.applications.push({
+    directory: 'apps/frontend-app-e2e',
+    projectJson: { name: 'frontend-app-e2e', tags: ['scope:frontend-app', 'type:e2e'] },
+  });
+
+  assert.deepEqual(checkWorkspaceNaming(workspace), []);
+});
