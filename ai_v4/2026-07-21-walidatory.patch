-#!/usr/bin/env node
-import { readFileSync, existsSync, readdirSync } from 'fs';
-import path from 'path';
-import { LIBRARY_NAMING } from '../generators/utils/naming-config.js';
-
-/* ─────────────────────────────────────────────────────────────────────────── *
- * Naming validator — deterministyczny CLI utility do wykrywania niespójności
- * między tsconfig path_aliases a faktyczną strukturą katalogów libs/.
- *
- * Reguła (z docs/standards/nx.md):
- *   Directory AND alias MUST: `<basePath>/<kontekst>/<type>[/<name>]` where <type>
- *   SINGULAR (feature, state, ui, core, model, util, asset); kontekst ZAWSZE
- *   przed typem; brak <name> = biblioteka-barrel typu w kontekście.
- *
- * Wykrywane violations:
- *   1. alias-path-missing — alias wskazuje na nieistniejący katalog
- *   2. alias-plural-type — alias zawiera plural type ("features", "states", ...)
- *   3. directory-plural-type — katalog ma plural type w nazwie
- *   4. directory-missing-alias — katalog libs/.../src istnieje,
- *      ale brak zarejestrowanego aliasu w tsconfig
- *   5. alias-format-invalid — alias nie pasuje do żadnej z dwóch gramatyk (niżej)
- *   6. alias-type-unknown — segment <type> aliasu nie jest dozwolonym typem
- *      (łapie odwróconą kolejność <type>/<kontekst>, np. `core/auth` zamiast `auth/core`)
- *
- * Dwie gramatyki aliasów (model app-agnostyczny — SSOT: nx.md, library-naming.js):
- *   - REUŻYWALNE (prefix === sharedPrefix): `@<sharedPrefix>/<scope>/<kontekst>/<type>[/<name>]`
- *     — scope (np. shared) jest segmentem ścieżki, po nim kontekst, po nim type.
- *   - APP-OWE   (prefix !== sharedPrefix): `@<prefix>/<kontekst>/<type>[/<name>]`
- *     — apka jest W prefiksie, więc scope NIE powtarza się; kontekst PIERWSZY, type po nim.
- * Dyskryminator = czy prefiks aliasu równa się sharedPrefix. Segment na pozycji
- * <type> musi być typem — to wykrywa odwróconą kolejność w OBU gramatykach.
- *
- * Output:
- *   - human: tabela violations na stdout (default)
- *   - json: structured JSON
- *   - yaml: structured YAML (do embedu w system-constraints.yaml)
- *
- * Exit code: 0 jeśli zero violations, 1 jeśli są (do CI).
- *
- * Użycie:
- *   node scripts/validators/naming-validator.js [--format=human|json|yaml] [--root=.]
- *     [--shared-prefix=<prefix>]
- * ─────────────────────────────────────────────────────────────────────────── */
-
-const ALLOWED_TYPES = ['feature', 'state', 'ui', 'core', 'model', 'util', 'asset'];
-const PLURAL_OF = {
-  features: 'feature',
-  states:   'state',
-  uis:      'ui',
-  cores:    'core',
-  models:   'model',
-  utils:    'util',
-  assets:   'asset',
-};
-
-function main() {
-  const args = parseArgs(process.argv.slice(2));
