-}
-
-// ── Helpers ────────────────────────────────────────────────────────────────
-
-/**
- * Walk libs/ w poszukiwaniu katalogów bibliotek. Library = katalog zawierający `src/`.
- */
-function walkLibs(libsRoot) {
