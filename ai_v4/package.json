{
  "name": "gdprrt-frontend",
  "version": "2.0.0",
  "scripts": {
    "nx": "nx",
    "start:frontend-app:local": "nx serve --project=frontend-app --configuration=dev",
    "start:frontend-app:dev": "nx serve --project=frontend-app --configuration=dev",
    "start:frontend-app:prod": "nx serve --project=frontend-app --configuration=production",
    "start:frontend-app:docker": "nx serve --project=frontend-app --configuration=docker --host 0.0.0.0",
    "build:frontend-app:local": "nx build --project=frontend-app",
    "build:frontend-app:dev": "nx build --project=frontend-app --configuration=dev",
    "build:frontend-app:proddocker": "nx build --project=frontend-app --configuration=docker",
    "build:frontend-app:prod": "nx build --project=frontend-app --configuration=production",
    "build-analyzer:frontend-app": "nx build --project=frontend-app --configuration=production --stats-json && npm run analyzer:frontend-app",
    "generators:build": "cd ./generators && npm run schematics:build",
    "generators:link": "npm i --legacy-peer-deps --no-save ./generators/generators-1.0.0.tgz",
    "generators-prepare": "npm run generators:build && npm run generators:link",
    "init-state": "nx g generators:init-state",
    "endpoint:frontend-app": "nx g generators:endpoint",
    "analyzer:frontend-app": "webpack-bundle-analyzer dist/frontend-app/stats.json",
    "test": "vitest",
    "test:scripts": "node --test \"scripts/**/*.test.js\"",
    "test:story-flow": "node --test \".ai-agentic-workspace/workflows/**/*.test.js\" \".ai-agentic-workspace/scripts/**/*.test.js\" \"scripts/**/*.test.js\"",
    "figma:audit": "node .ai-agentic-workspace/workflows/figma-audit/runner.js",
    "lint": "nx lint --project=frontend-app",
    "lint:scripts": "eslint scripts --max-warnings=0",
    "lint:repo": "npm run lint:scripts && npm run validate:naming",
    "validate:naming": "node scripts/validators/naming-validator.js",
    "validate:readme": "node scripts/validators/readme-validator.js",
    "lint:fix": "nx lint --project=frontend-app --fix",
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "cleanup-unused-imports": "nx generate @angular/core:cleanup-unused-imports",
    "code-index:graph": "node .ai-agentic-workspace/scripts/code-index/viz/code-index-graph.js --open",
    "translate-i18n-service": "http-server ./../ localhost -p 8099 --cors",
    "translate-i18n-service2": "http-server ./../../gdprrt/ localhost -p 8099 --cors"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "21.2.8",
    "@angular/animations": "21.2.10",
    "@angular/cdk": "21.2.8",
    "@angular/common": "21.2.10",
