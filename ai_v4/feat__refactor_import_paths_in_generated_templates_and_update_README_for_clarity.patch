+/* ── importy wygenerowanego kodu ───────────────────────────────────────────── */
+
+/** Wszystkie importy z aliasu workspace'u (`@…`), z wygenerowanych plików. */
+function collectWorkspaceImports(rootPath) {
+  const found = new Set();
+
+  const walk = (dirPath) => {
+    for (const entry of fs.readdirSync(dirPath, { withFileTypes: true })) {
+      const entryPath = path.join(dirPath, entry.name);
+      if (entry.isDirectory()) {
+        walk(entryPath);
+        continue;
+      }
+      for (const match of fs.readFileSync(entryPath, 'utf-8').matchAll(/from '(@[^']+)'/g)) {
+        found.add(match[1]);
+      }
+    }
+  };
+
+  walk(rootPath);
+  return [...found].sort();
+}
+
+test('wygenerowane importy wskazują na aliasy, które naprawdę są w workspace', async (t) => {
+  const target = makeTempDir(t);
+  await runInitState({ options: { name: 'session', path: target }, positionals: [] });
+
+  const tsconfig = JSON.parse(fs.readFileSync('tsconfig.base.json', 'utf-8'));
+  const aliases = Object.keys(tsconfig.compilerOptions.paths);
+
+  // Pakiety zewnętrzne (@angular/core, @ngxs/store) nie należą do workspace'u,
+  // więc sprawdzane są tylko aliasy o prefiksie stąd — te, które ten generator składa.
+  const workspacePrefixes = [...new Set(aliases.map((alias) => alias.split('/')[0]))];
+  const wygenerowane = collectWorkspaceImports(target).filter((used) =>
+    workspacePrefixes.includes(used.split('/')[0]),
+  );
+
+  assert.ok(wygenerowane.length > 0, 'generator ma importować z bibliotek workspace');
+  for (const used of wygenerowane) {
+    assert.ok(aliases.includes(used), `import "${used}" nie ma odpowiednika w tsconfig.base.json`);
+  }
+});
+
+test('index.ts wystawia wyłącznie fasadę i providera, nazwanymi eksportami', async (t) => {
+  const target = makeTempDir(t);
+  await runInitState({ options: { name: 'session', path: target }, positionals: [] });
+
+  const index = fs.readFileSync(path.join(target, 'index.ts'), 'utf-8');
+
+  assert.equal(
+    index.trim(),
+    [
+      "export { SessionStateService } from './session-state.service';",
+      "export { sessionStateProviders } from './session-state-providers';",
+    ].join('\n'),
+  );
+});
+
+test('--shared-prefix zmienia prefiks aliasu, reszta ścieżki zostaje', async (t) => {
+  const target = makeTempDir(t);
+  await runInitState({ options: { name: 'session', path: target, sharedPrefix: 'acme' }, positionals: [] });
+
+  const uzyte = collectWorkspaceImports(target).filter((used) => used.startsWith('@acme/'));
+
+  assert.deepEqual(uzyte, ['@acme/shared/common/core/api', '@acme/shared/common/core/state']);
+});
