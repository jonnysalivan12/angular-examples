@@ -0,0 +1,33 @@
+import { deriveLibraryNaming } from '../../utils/library-naming.js';
+
+/* ─────────────────────────────────────────────────────────────────────────── *
+ * Aliasy bibliotek, po które sięga wygenerowany kod stanu.
+ *
+ * Biblioteki opisane są STRUKTURĄ (zakres, kontekst, typ, nazwa), a alias
+ * powstaje z niej tą samą funkcją, której używa generator bibliotek. Ścieżka
+ * pisana ręcznie rozjeżdżała się z tsconfig.base.json po cichu: wygenerowany
+ * plik importował z aliasu, którego nie ma, a widać to było dopiero przy
+ * kompilacji kodu, który powstał.
+ * ─────────────────────────────────────────────────────────────────────────── */
+
+/** Biblioteka z elementami NGXS: ActionBuilder, NgxsEffectsService, Effect. */
+const STATE_LIBRARY = Object.freeze({ scope: 'shared', context: 'common', type: 'core', name: 'state' });
+
+/** Biblioteka z klientem HTTP: ApiService. */
+const API_LIBRARY = Object.freeze({ scope: 'shared', context: 'common', type: 'core', name: 'api' });
+
+/**
+ * Aliasy importu obu bibliotek.
+ *
+ * @param {{sharedPrefix?: string}} [options] — `sharedPrefix` nadpisuje prefiks
+ *   z konfiguracji, gdy generator biegnie na innym workspace
+ * @returns {{state: string, api: string}}
+ */
+export function stateImports(options = {}) {
+  const naming = options?.sharedPrefix ? { sharedPrefix: options.sharedPrefix } : {};
+
+  return {
+    state: deriveLibraryNaming(STATE_LIBRARY, naming).importPath,
+    api: deriveLibraryNaming(API_LIBRARY, naming).importPath,
+  };
+}
