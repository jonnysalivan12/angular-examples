type MockedClass<T> = {
  [K in keyof T]: T[K] extends (...args: any[]) => any
    ? jest.MockedFunction<T[K]>
    : T[K];
};

class AutoMock {
  static make<T>(ClassConstructor: new (...args: any[]) => T): MockedClass<T> {
    const instance = new ClassConstructor();
    const mock: any = {};
    const prototype = Object.getPrototypeOf(instance);

    let currentProto = prototype;
    
    // Przechodzimy przez cały łańcuch prototypów
    while (currentProto && currentProto !== Object.prototype) {
      Object.getOwnPropertyNames(currentProto).forEach((key) => {
        if (key !== 'constructor' && !mock[key]) {
          const descriptor = Object.getOwnPropertyDescriptor(currentProto, key);
          
          if (descriptor && typeof descriptor.value === 'function') {
            mock[key] = jest.fn();
          }
        }
      });
      
      currentProto = Object.getPrototypeOf(currentProto);
    }

    return mock as MockedClass<T>;
  }
}
